---
interface Props {
  title: string;
  paragraphs: string[];
}

const { title, paragraphs } = Astro.props;
---

<section class="intro-section">
  <div class="container intro-section__inner">
    <div class="intro-section__text">
      <h2 class="intro-section__title">{title}</h2>
      {paragraphs.map((p) => (
        <p class="intro-section__paragraph">{p}</p>
      ))}
    </div>
    <div class="intro-section__media">
      <div class="intro-section__placeholder">
        <span class="label-mono">optionales Bild</span>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-section {
    padding-top: var(--section-space);
    padding-bottom: var(--section-space);
  }

  .intro-section__inner {
    display: grid;
    grid-template-columns: 1fr 282px;
    gap: 60px;
  }

  .intro-section__title {
    font-size: 2rem;
    font-weight: 500;
    margin: 0 0 24px;
    line-height: 1.2;
  }

  .intro-section__paragraph {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-800);
    margin: 0 0 16px;
    max-width: 760px;
  }

  .intro-section__paragraph:last-child {
    margin-bottom: 0;
  }

  .intro-section__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .intro-section__placeholder {
    width: 100%;
    aspect-ratio: 1 / 1.28;
    background: var(--color-gray-200);
    border: 1px solid var(--color-gray-300);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .intro-section__placeholder .label-mono {
    color: var(--color-gray-500);
  }

  @media (max-width: 1024px) {
    .intro-section__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .intro-section__media {
      justify-content: flex-start;
    }

    .intro-section__placeholder {
      max-width: 282px;
      aspect-ratio: 1 / 1;
    }
  }
</style>
