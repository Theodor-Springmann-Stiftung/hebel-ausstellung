---
import type { Artwork } from "../data/artworks";

interface Props {
  artworks: Artwork[];
  currentId: string;
  basePath: string;
}

const { artworks, currentId, basePath } = Astro.props;
const currentIndex = artworks.findIndex((a) => a.id === currentId);
const prevArtwork = artworks[currentIndex - 1];
const nextArtwork = artworks[currentIndex + 1];
---

<section class="thumbnail-strip" data-thumbnail-strip>
  <div class="container thumbnail-strip__inner">
    {artworks.map((artwork, index) => {
      const isActive = artwork.id === currentId;
      return (
        <a
          href={`${basePath}/${artwork.id}`}
          class="thumbnail-strip__item"
          data-active={isActive}
          aria-current={isActive ? "true" : undefined}
        >
          <div class="thumbnail-strip__image">
            <span class="thumbnail-strip__number label-mono">{String(index + 1).padStart(2, "0")}</span>
          </div>
          <span class="thumbnail-strip__title">{artwork.thumbnailTitle}</span>
        </a>
      );
    })}
  </div>

  <!-- Hidden prev/next metadata for JS keyboard navigation -->
  {prevArtwork && (
    <meta name="thumbnail-prev" content={`${basePath}/${prevArtwork.id}`} />
  )}
  {nextArtwork && (
    <meta name="thumbnail-next" content={`${basePath}/${nextArtwork.id}`} />
  )}
</section>

<style>
  .thumbnail-strip {
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .thumbnail-strip__inner {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 12px;
  }

  .thumbnail-strip__item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .thumbnail-strip__item[data-active="true"] .thumbnail-strip__image {
    outline: 2px solid var(--color-black);
    outline-offset: -2px;
  }

  .thumbnail-strip__item[data-active="true"] .thumbnail-strip__title {
    color: var(--color-black);
    font-weight: 500;
  }

  .thumbnail-strip__image {
    position: relative;
    aspect-ratio: 3 / 4;
    background: var(--color-gray-200);
    border: 1px solid var(--color-gray-300);
  }

  .thumbnail-strip__number {
    position: absolute;
    top: 6px;
    left: 6px;
    background: rgba(255, 255, 255, 0.85);
    padding: 2px 6px;
    font-size: 0.625rem;
  }

  .thumbnail-strip__title {
    font-size: 0.75rem;
    line-height: 1.3;
    color: var(--color-gray-600);
  }

  @media (max-width: 1024px) {
    .thumbnail-strip__inner {
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
    }
  }

  @media (max-width: 768px) {
    .thumbnail-strip__inner {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
