---
import { site } from "../../data/site";

type ChapterLink = {
  nummer: string;
  titel: string;
  href: string;
};

const { chapters, currentPath } = Astro.props as { chapters: ChapterLink[]; currentPath: string };
// INFO: we normalize the path to be able to correctly determine where we are
const normalizedPath = currentPath.endsWith('/') ? currentPath : `${currentPath}/`;
const isUeberActive = normalizedPath === '/ueber/';
const isKontaktActive = normalizedPath === '/kontakt/';
---

<nav class="desktop-navigation" aria-label="Hauptnavigation">
  <div class="desktop-navigation__inner">
    <a class="desktop-navigation__brand" href="/" aria-label="Startseite">
      <span class="desktop-navigation__brand-kicker">{site.tagline}</span>
      <span class="desktop-navigation__brand-title">{site.title}</span>
    </a>

    <div class="desktop-navigation__links">
      <details class="desktop-navigation__dropdown">
        <summary class="nav-link desktop-navigation__dropdown-trigger">
          <span>Ausstellung</span>
          <svg class="desktop-navigation__chevron" viewBox="0 0 12 8" aria-hidden="true" focusable="false">
            <path d="M1 1.5 6 6.5 11 1.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.25" />
          </svg>
        </summary>

        <div class="desktop-navigation__dropdown-panel">
          <p class="type-caption desktop-navigation__dropdown-label">Kapitel der Ausstellung</p>
          <ol class="desktop-navigation__chapter-list">
            {chapters.map((chapter) => (
              <li class="desktop-navigation__chapter-item">
                <a class="desktop-navigation__chapter-link" href={chapter.href} aria-current={normalizedPath.startsWith(chapter.href) ? 'location' : undefined}>
                  <span class="type-caption-small desktop-navigation__chapter-number">{chapter.nummer}</span>
                  <span class="type-body-medium desktop-navigation__chapter-title">{chapter.titel}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </details>

      <a class="nav-link desktop-navigation__link" href="/ueber/" aria-current={isUeberActive ? 'page' : undefined}>Über die Ausstellung</a>
      <a class="nav-link desktop-navigation__link" href="/kontakt/" aria-current={isKontaktActive ? 'page' : undefined}>Kontakt</a>
    </div>
  </div>
</nav>

<style>
  @reference "../../styles/global.css";

  .desktop-navigation {
    @apply hidden w-full;

    border-bottom: 0.5px solid var(--color-ink);
    background-color: var(--color-paper, #f7f7f4);
  }

  .desktop-navigation__inner {
    @apply mx-auto flex w-full items-center justify-between;

    max-width: var(--container-chrome);
    padding: var(--spacing-16) var(--spacing-32);
  }

  .desktop-navigation__brand {
    @apply flex flex-col text-text-primary no-underline;

    width: 375px;
    gap: var(--spacing-4);
  }

  .desktop-navigation__brand-kicker {
    @apply font-sans text-body-medium;

    line-height: var(--text-body-medium--line-height);
  }

  .desktop-navigation__brand-title {
    @apply font-display text-h3;

    line-height: var(--text-h3--line-height);
  }

  .desktop-navigation__links {
    @apply flex items-center;

    gap: var(--spacing-48);
  }

  .desktop-navigation__dropdown {
    @apply relative;
  }

  .desktop-navigation__dropdown-trigger {
    @apply flex cursor-pointer list-none items-center no-underline select-none;

    gap: var(--spacing-8);
    border-bottom: 1.5px solid transparent;
    padding-block: 7.5px 8.75px;
    line-height: var(--text-body--line-height);
  }

  .desktop-navigation__link {
    @apply no-underline select-none;

    border-bottom: 1.5px solid transparent;
    padding-block: 7.5px 8.75px;
    line-height: var(--text-body--line-height);
  }

  .desktop-navigation__dropdown-trigger:hover,
  .desktop-navigation__link:hover {
    @apply no-underline;

    border-bottom-color: currentColor;
  }

  .desktop-navigation__dropdown-trigger::-webkit-details-marker {
    @apply hidden;
  }

  .desktop-navigation__chevron {
    @apply flex-none overflow-visible;

    width: 12px;
    height: 8px;
  }

  .desktop-navigation__dropdown[open] > .desktop-navigation__dropdown-trigger {
    @apply no-underline;

    border-bottom-color: currentColor;
  }

  .desktop-navigation__dropdown-panel {
    @apply absolute z-10;

    top: calc(100% + var(--spacing-16));
    right: -120px;
    width: 320px;
    padding: var(--spacing-24);
    background-color: var(--color-paper, #f7f7f4);
    box-shadow: 6px 6px 5px rgb(0 0 0 / 15%);
  }

  .desktop-navigation__dropdown-label {
    @apply text-text-secondary;

    margin-bottom: var(--spacing-24);
  }

  .desktop-navigation__chapter-list {
    @apply m-0 flex list-none flex-col p-0;

    gap: var(--spacing-16);
  }

  .desktop-navigation__chapter-item:not(:last-child) {
    padding-bottom: var(--spacing-16);
    border-bottom: 0.5px solid rgb(38 37 30 / 50%);
  }

  .desktop-navigation__chapter-link {
    @apply flex items-center text-text-primary no-underline select-none;

    gap: var(--spacing-16);
  }

  .desktop-navigation__chapter-link:hover .desktop-navigation__chapter-title,
  .desktop-navigation__chapter-link[aria-current] .desktop-navigation__chapter-title {
    @apply text-link underline;

    text-underline-offset: 0.16em;
  }

  .desktop-navigation__link[aria-current] {
    border-bottom-color: currentColor;
  }

  .desktop-navigation__chapter-number {
    @apply text-text-secondary;

    width: var(--spacing-24);
  }

  .desktop-navigation__chapter-title {
    @apply flex-1;
  }

  @media (min-width: 1440px) {
    .desktop-navigation {
      @apply block;
    }

    .desktop-navigation__inner {
      padding-inline: var(--spacing-80);
    }
  }

  @media (min-width: 1920px) {
    .desktop-navigation__inner {
      padding-inline: var(--spacing-80);
    }
  }
</style>
