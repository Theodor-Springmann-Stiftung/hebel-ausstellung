---
import DesktopNavigation from "./DesktopNavigation.astro";
import MobileNavigation from "./MobileNavigation.astro";
import { getChapterNavigation } from "../../lib/content";

const chapters = await getChapterNavigation();
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header class:list={{ "top-navigation": true, "top-navigation--home": isHome }}>
  <DesktopNavigation chapters={chapters} currentPath={currentPath} isHome={isHome} />
  <MobileNavigation chapters={chapters} currentPath={currentPath} />
</header>

<style>
  @reference "../../styles/global.css";

  .top-navigation {
    @apply relative z-10 w-full;
  }

  @media (min-width: 1440px) {
    .top-navigation--home {
      @apply absolute left-0 top-0;
    }
  }
</style>
