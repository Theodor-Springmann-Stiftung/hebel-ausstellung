---
import { execFileSync } from "node:child_process";
import portrait from "../../assets/objects/Hebel_Portraet_Mueller.jpg";
import { site } from "../../data/site";

const footerLinks = [
  { label: "Über die Ausstellung", href: "/ueber/" },
  { label: "Team & Partners", href: "#team-partners" },
  { label: "Presse Kontakt", href: "#presse-kontakt" },
  { label: "Kontakt Uns", href: "/kontakt/" },
  { label: "Mitwirkende / Credits", href: "#credits" },
  { label: "Impressum & Datenschutz", href: "#impressum-datenschutz" },
  { label: "Datenschutz / Barrierefreiheit", href: "/datenschutz/" },
];

const readGitValue = (args: string[]) => {
  try {
    return execFileSync("git", args, {
      cwd: process.cwd(),
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    }).trim();
  } catch {
    return null;
  }
};

const commitHash = readGitValue(["rev-parse", "--short", "HEAD"]);
const commitDate = readGitValue(["show", "-s", "--format=%cd", "--date=format:%d.%m.%Y", "HEAD"]);
const footerTitleParts = site.title.split(" der ");
---

<footer class="site-footer" aria-labelledby="footer-title">
  <div class="site-footer__inner">
    <div class="site-footer__columns">
      <section class="site-footer__exhibition" aria-labelledby="footer-title">
        <p class="site-footer__eyebrow">Ausstellung</p>
        <div class="site-footer__intro">
          <div class="site-footer__title-group">
            <p class="site-footer__kicker">{site.tagline}</p>
            <h2 class="site-footer__title" id="footer-title">
              {footerTitleParts[0]}{footerTitleParts[1] && <><br />der {footerTitleParts[1]}</>}
            </h2>
          </div>
          <p class="site-footer__description">{site.footerTagline}</p>
        </div>
      </section>

      <nav class="site-footer__section site-footer__about" aria-labelledby="footer-about-title">
        <p class="site-footer__eyebrow" id="footer-about-title">Über Uns</p>
        <ul class="site-footer__link-list">
          {footerLinks.map((link) => (
            <li>
              <a class="site-footer__link" href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <section class="site-footer__section site-footer__contact" aria-labelledby="footer-contact-title">
        <p class="site-footer__eyebrow" id="footer-contact-title">Kontakt</p>
        <div class="site-footer__portrait-frame" aria-hidden="true">
          <img class="site-footer__portrait" src={portrait.src} alt="" loading="lazy" decoding="async" />
        </div>
        <address class="site-footer__address">
          Johann Peter Hebel-Archiv<br />
          Theodor Springmann Stiftung<br />
          Hirschgasse 2<br />
          69120 Heidelberg<br />
          <a class="site-footer__email" href="mailto:info@hebel-archiv.de">info@hebel-archiv.de</a>
        </address>
      </section>
    </div>
  </div>

  <div class="site-footer__legal">
    <p>{site.copyright}</p>
    {commitHash && commitDate && (
      <p class="site-footer__commit">
        Commit <a class="site-footer__commit-link" href={site.repositoryUrl}>{commitHash}</a>, {commitDate}
      </p>
    )}
  </div>
</footer>

<style>
  @reference "../../styles/global.css";

  .site-footer {
    --footer-heading-gap: var(--spacing-16);

    @apply bg-ink text-paper;
  }

  .site-footer__inner {
    @apply mx-auto flex w-full flex-col;

    padding: var(--spacing-56) var(--spacing-20) 0;
  }

  .site-footer__columns {
    @apply flex flex-col items-start;

    gap: var(--spacing-80);
    padding-bottom: var(--spacing-40);
  }

  .site-footer__exhibition,
  .site-footer__section,
  .site-footer__intro,
  .site-footer__title-group {
    @apply grow-0 flex flex-col items-start;
  }

  .site-footer__exhibition,
  .site-footer__section {
    gap: var(--footer-heading-gap);
  }

  .site-footer__intro {
    gap: var(--spacing-40);
    width: 100%;
  }

  .site-footer__title-group {
    gap: var(--spacing-8);
    width: 100%;
  }

  .site-footer__eyebrow,
  .site-footer__legal {
    @apply font-mono text-caption-small font-normal uppercase;

    letter-spacing: var(--text-caption-small--letter-spacing);
    line-height: var(--text-caption-small--line-height);
  }

  .site-footer__kicker {
    @apply font-sans text-lead;

    line-height: var(--text-lead--line-height);
  }

  .site-footer__title {
    @apply w-full font-display text-display font-normal text-inherit;

    line-height: var(--text-display--line-height);
  }

  .site-footer__description {
    @apply font-sans text-body-medium;

    line-height: var(--text-body-medium--line-height);
  }

  .site-footer__link-list {
    @apply m-0 flex w-full list-none flex-col p-0;

    gap: var(--spacing-20);
  }

  .site-footer__link {
    @apply inline-flex font-sans text-lead text-inherit no-underline;

    padding-block: var(--spacing-8);
    line-height: var(--text-lead--line-height);
  }

  .site-footer__link:hover {
    opacity: 0.72;
  }

  .site-footer__contact {
    @apply w-full;
  }

	/* mt-1 to visually align the header distance to the picture with the other columns */
  .site-footer__portrait-frame {
    @apply overflow-hidden mt-1;

    width: 280px;
    height: 78px;
    border: 1px solid var(--color-paper);
  }

  .site-footer__portrait {
    @apply h-full w-full object-cover object-center;
  }

  .site-footer__address,
  .site-footer__address a {
    @apply font-sans text-body not-italic text-inherit no-underline;

    line-height: var(--text-body--line-height);
  }

  .site-footer__address a:hover {
    @apply underline;
  }

  .site-footer__address .site-footer__email {
    @apply italic;
  }

  .site-footer__legal {
    @apply flex flex-wrap items-center justify-between whitespace-nowrap;

    border-top: 0.25px solid var(--color-paper);
    gap: var(--spacing-8) var(--spacing-20);
    padding: var(--spacing-16) var(--spacing-20);
  }

  .site-footer__commit {
    @apply ml-auto text-right;
  }

  .site-footer__commit-link {
    @apply text-inherit underline;
  }

  .site-footer__commit-link:hover {
    opacity: 0.72;
  }

  @media (min-width: 768px) {
    .site-footer__inner {
      padding: var(--spacing-40) var(--spacing-32) 0;
    }

    .site-footer__legal {
      padding-inline: var(--spacing-32);
    }

    .site-footer__columns {
      @apply grid items-start;

      grid-template-columns: 240px minmax(0, 1fr);
      gap: 31px;
      padding-bottom: var(--spacing-64);
    }

    .site-footer__exhibition {
      width: 240px;
      grid-column: 1;
      grid-row: 1 / span 2;
    }

    .site-footer__about,
    .site-footer__contact {
      grid-column: 2;
    }

    .site-footer__about {
      grid-row: 1;
    }

    .site-footer__contact {
      grid-row: 2;
      margin-top: var(--spacing-56);
    }

    .site-footer__intro {
      gap: var(--spacing-24);
    }

    .site-footer__kicker {
      font-size: var(--text-body);
      line-height: var(--text-body--line-height);
    }

    .site-footer__title {
      font-size: var(--text-h2);
      line-height: var(--text-h2--line-height);
    }

    .site-footer__description,
    .site-footer__link,
    .site-footer__address,
    .site-footer__address a {
      font-size: var(--text-body-medium);
      line-height: var(--text-body-medium--line-height);
    }

    .site-footer__link-list {
      gap: var(--spacing-12);
    }

    .site-footer__link {
      padding-block: 0;
    }

    .site-footer__portrait-frame {
      width: 252px;
      height: 71px;
      border-color: var(--color-paper);
    }
  }

  @media (min-width: 1440px) {
    .site-footer__inner {
      --footer-heading-gap: var(--spacing-24);

      max-width: var(--container-chrome);
      padding: 60px var(--spacing-80) 0;
    }

    .site-footer__columns {
      @apply grid items-start;

      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-64);
      min-height: 359px;
      padding-bottom: var(--spacing-80);
    }

    .site-footer__exhibition {
      width: auto;
      grid-column: auto;
      grid-row: auto;
      gap: var(--spacing-24);
    }

    .site-footer__about {
      grid-column: auto;
      grid-row: auto;
      justify-self: center;
    }

    .site-footer__contact {
      grid-column: auto;
      grid-row: auto;
      margin-top: 0;
      justify-self: end;
    }

    .site-footer__title {
      font-size: var(--text-h1);
      line-height: var(--text-h1--line-height);
    }

    .site-footer__description {
      width: 389px;
    }

    .site-footer__link-list {
      gap: 0;
    }

    .site-footer__link {
      padding-block: 6px;
    }

    .site-footer__portrait-frame {
      width: 265px;
      height: 123px;
      border-color: #cfcfcf;
    }

    .site-footer__legal {
      padding: 18.5px var(--spacing-80) 18px;
      border-top: 0.5px solid var(--color-surface);
    }
  }
</style>
