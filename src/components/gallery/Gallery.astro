---
import { markdownToPlainText, renderInlineMarkdown, serializeForScript } from "../../lib/markdown";
import type { GalleryImageSource } from "../../lib/object-images";

export type GalleryColor =
  | "lindgrün"
  | "vanille"
  | "hellblau"
  | "mintgrün"
  | "rosa"
  | "himmelblau"
  | "salbeigrün";

export type GalleryObject = {
  slug?: string;
  position?: "Links" | "Rechts" | "Vorne";
  transkription: boolean;
  titel: string;
  urheber?: string;
  datierung?: string;
  materialTechnik?: string;
  institution?: string;
};

export type GalleryImage = {
  src: GalleryImageSource;
  alt?: string;
  beschriftung?: string;
  nachweis?: string;
  objekte?: GalleryObject[];
};

type CaptionItem = {
  titleHtml: string;
  textHtml: string;
  href?: string;
  linkLabel?: string;
};

export type GalleryProps = {
  titel: string;
  beschriftung?: string;
  untertitel?: string;
  farbe?: GalleryColor;
  bilder: GalleryImage[];
};

const props = Astro.props as GalleryProps;
const { titel, beschriftung, untertitel, farbe = "lindgrün", bilder } = props;
const isMultiImage = bilder.length > 1;

const objectMetadata = (object: GalleryObject) =>
  [
    object.urheber,
    object.datierung,
    object.materialTechnik,
    object.institution,
  ]
    .filter(Boolean)
    .map((value) => renderInlineMarkdown(value))
    .join(", ");

const getCaptionItems = (image: GalleryImage): CaptionItem[] => {
  if (image.objekte?.length) {
    return image.objekte.map((object) => {
      return {
        titleHtml: renderInlineMarkdown(image.beschriftung ?? (object.position ? `${object.position}: ${object.titel}` : object.titel)),
        textHtml: objectMetadata(object),
        href: object.slug ? `/objekte/${object.slug}/${object.position ? `?position=${encodeURIComponent(object.position)}` : ""}` : undefined,
        linkLabel: object.transkription ? "Zum Objekt (mit Transkription)" : "Zum Objekt",
      };
    });
  }

  if (image.beschriftung || image.nachweis) {
    return [
      {
        titleHtml: renderInlineMarkdown(image.beschriftung),
        textHtml: renderInlineMarkdown(image.nachweis),
      },
    ];
  }

  return [
    {
      titleHtml: renderInlineMarkdown(beschriftung),
      textHtml: renderInlineMarkdown(untertitel),
    },
  ];
};

const slides = bilder.map((image, index) => ({
  index,
  src: image.src.src,
  srcset: image.src.srcset,
  sizes: image.src.sizes,
  peekSrc: image.src.peekSrc,
  alt: markdownToPlainText(image.alt),
  captions: getCaptionItems(image),
}));

const firstSlide = slides[0];
const nextSlide = slides[1] ?? firstSlide;
---

<section class:list={["gallery", isMultiImage ? "gallery--multi" : "gallery--single"]} data-gallery data-color={farbe} aria-roledescription={isMultiImage ? "carousel" : undefined} aria-label={markdownToPlainText(titel)}>
  <div class="gallery__title-section">
    <h2 class="gallery__title" set:html={renderInlineMarkdown(titel)}></h2>
  </div>

  <div class="gallery__stage">
    {isMultiImage && (
      <button class="gallery__button gallery__button--prev" type="button" data-gallery-prev aria-label="Vorheriges Bild" disabled>
        <svg class="gallery__button-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M19 12H5m6-6-6 6 6 6" />
        </svg>
      </button>
    )}

    {isMultiImage && (
      <div class="gallery__peek gallery__peek--prev is-empty" aria-hidden="true" data-gallery-peek-prev>
        <img src={firstSlide.peekSrc} alt="" data-gallery-peek-prev-image />
      </div>
    )}

    <figure class="gallery__frame">
      <div class="gallery__mat">
        <img
          class="gallery__image"
          src={firstSlide.src}
          srcset={firstSlide.srcset}
          sizes={firstSlide.sizes}
          alt={firstSlide.alt}
          loading="lazy"
          decoding="async"
          data-gallery-image
        />
      </div>
    </figure>

    {isMultiImage && (
      <div class="gallery__peek gallery__peek--next" class:list={{ "is-empty": slides.length < 2 }} aria-hidden="true" data-gallery-peek-next>
        <img src={nextSlide.peekSrc} alt="" data-gallery-peek-next-image />
      </div>
    )}

    {isMultiImage && (
      <button class="gallery__button gallery__button--next" type="button" data-gallery-next aria-label="Nächstes Bild">
        <svg class="gallery__button-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M5 12h14m-6-6 6 6-6 6" />
        </svg>
      </button>
    )}
  </div>

  <div class="gallery__caption-section" data-gallery-caption aria-live="polite">
    {isMultiImage && (
      <div class="gallery__pagination">
        <div class="gallery__dots" data-gallery-dots>
          {slides.map((slide) => <button class="gallery__dot" type="button" data-gallery-dot={slide.index} aria-label={`Bild ${slide.index + 1} anzeigen`} aria-current={slide.index === 0 ? "true" : undefined}></button>)}
        </div>
        <p class="gallery__counter" data-gallery-counter>1 / {slides.length}</p>
      </div>
    )}

    <div class="gallery__caption-list">
      {firstSlide.captions.map((item) => (
        <div class="gallery__caption-item">
          {item.titleHtml && <p class="gallery__caption-title" set:html={item.titleHtml}></p>}
          {item.textHtml && <p class="gallery__caption-text" set:html={item.textHtml}></p>}
          {item.href && (
            <a class="gallery__object-link" href={item.href}>
              <span>{item.linkLabel}</span>
              <span class="gallery__object-link-arrow" aria-hidden="true">→</span>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>

  <script type="application/json" data-gallery-slides set:html={serializeForScript(slides)}></script>
</section>

<script>
  const renderCaption = (container: HTMLElement, captions: Array<{ titleHtml?: string; textHtml?: string; href?: string; linkLabel?: string }>) => {
    const captionList = document.createElement("div");
    captionList.className = "gallery__caption-list";

    captions.forEach((caption) => {
      const item = document.createElement("div");
      item.className = "gallery__caption-item";

      if (caption.titleHtml) {
        const title = document.createElement("p");
        title.className = "gallery__caption-title";
        title.innerHTML = caption.titleHtml;
        item.append(title);
      }

      if (caption.textHtml) {
        const text = document.createElement("p");
        text.className = "gallery__caption-text";
        text.innerHTML = caption.textHtml;
        item.append(text);
      }

      if (caption.href) {
        const link = document.createElement("a");
        link.className = "gallery__object-link";
        link.href = caption.href;

        const label = document.createElement("span");
        label.textContent = caption.linkLabel ?? "Zum Objekt";

        const arrow = document.createElement("span");
        arrow.className = "gallery__object-link-arrow";
        arrow.setAttribute("aria-hidden", "true");
        arrow.textContent = "→";

        link.append(label, arrow);
        item.append(link);
      }

      captionList.append(item);
    });

    const pagination = container.querySelector(".gallery__pagination");
    container.replaceChildren(...[pagination, captionList].filter(Boolean));
  };

  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const script = gallery.querySelector<HTMLScriptElement>("[data-gallery-slides]");
    const slides = script?.textContent ? JSON.parse(script.textContent) : [];

    if (slides.length <= 1) return;

    const image = gallery.querySelector<HTMLImageElement>("[data-gallery-image]");
    const previousImage = gallery.querySelector<HTMLImageElement>("[data-gallery-peek-prev-image]");
    const nextImage = gallery.querySelector<HTMLImageElement>("[data-gallery-peek-next-image]");
    const counter = gallery.querySelector<HTMLElement>("[data-gallery-counter]");
    const caption = gallery.querySelector<HTMLElement>("[data-gallery-caption]");
    const stage = gallery.querySelector<HTMLElement>(".gallery__stage");
    const previousButton = gallery.querySelector<HTMLButtonElement>("[data-gallery-prev]");
    const nextButton = gallery.querySelector<HTMLButtonElement>("[data-gallery-next]");
    const previousPeek = gallery.querySelector<HTMLElement>("[data-gallery-peek-prev]");
    const nextPeek = gallery.querySelector<HTMLElement>("[data-gallery-peek-next]");
    const dots = Array.from(gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-dot]"));
    let activeIndex = 0;
    let pointerStart: { id: number; x: number; y: number } | undefined;

    const setSlide = (nextIndex: number) => {
      activeIndex = Math.min(Math.max(nextIndex, 0), slides.length - 1);
      const slide = slides[activeIndex];
      const previousSlide = slides[activeIndex - 1];
      const nextSlide = slides[activeIndex + 1];

      if (image) {
        image.srcset = slide.srcset;
        image.sizes = slide.sizes;
        image.src = slide.src;
        image.alt = slide.alt;
      }

      if (previousImage && previousSlide) previousImage.src = previousSlide.peekSrc;
      if (nextImage && nextSlide) nextImage.src = nextSlide.peekSrc;
      previousPeek?.classList.toggle("is-empty", !previousSlide);
      nextPeek?.classList.toggle("is-empty", !nextSlide);
      if (previousButton) previousButton.disabled = activeIndex === 0;
      if (nextButton) nextButton.disabled = activeIndex === slides.length - 1;
      if (counter) counter.textContent = `${activeIndex + 1} / ${slides.length}`;
      if (caption) renderCaption(caption, slide.captions);

      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.toggleAttribute("aria-current", isActive);
      });
    };

    gallery.querySelector("[data-gallery-prev]")?.addEventListener("click", () => setSlide(activeIndex - 1));
    gallery.querySelector("[data-gallery-next]")?.addEventListener("click", () => setSlide(activeIndex + 1));

    stage?.addEventListener("pointerdown", (event) => {
      if ((event.target as HTMLElement).closest("button, a")) return;
      pointerStart = { id: event.pointerId, x: event.clientX, y: event.clientY };
    });

    stage?.addEventListener("pointerup", (event) => {
      if (!pointerStart || pointerStart.id !== event.pointerId) return;

      const deltaX = event.clientX - pointerStart.x;
      const deltaY = event.clientY - pointerStart.y;
      pointerStart = undefined;

      if (Math.abs(deltaX) < 40 || Math.abs(deltaX) <= Math.abs(deltaY)) return;
      if (deltaX > 0 && activeIndex === 0) return;
      if (deltaX < 0 && activeIndex === slides.length - 1) return;
      setSlide(deltaX < 0 ? activeIndex + 1 : activeIndex - 1);
    });

    stage?.addEventListener("pointercancel", () => {
      pointerStart = undefined;
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => setSlide(Number(dot.dataset.galleryDot ?? 0)));
    });
  });
</script>

<style>
  @reference "../../styles/global.css";

  .gallery {
    --gallery-mat-bg: var(--color-oat);
    --gallery-border: var(--color-ink);

    @apply flex w-full flex-col overflow-hidden bg-paper text-text-primary;
  }

  .gallery[data-color="lindgrün"] {
    --gallery-mat-bg: #d3e2c6;
  }

  .gallery[data-color="vanille"] {
    --gallery-mat-bg: rgb(255 250 204 / 40%);
  }

  .gallery[data-color="hellblau"] {
    --gallery-mat-bg: #cce6f1;
  }

  .gallery[data-color="mintgrün"] {
    --gallery-mat-bg: rgb(214 255 225 / 70%);
  }

  .gallery[data-color="rosa"] {
    --gallery-mat-bg: #ffe8e5;
  }

  .gallery[data-color="himmelblau"] {
    --gallery-mat-bg: rgb(177 203 247 / 40%);
  }

  .gallery[data-color="salbeigrün"] {
    --gallery-mat-bg: rgb(141 151 132 / 40%);
  }

  .gallery__title-section {
    padding: var(--spacing-40) var(--spacing-20) var(--spacing-24);
  }

  .gallery__title {
    @apply font-display text-h2 font-normal text-inherit;

    width: 100%;
    line-height: var(--text-h2--line-height);
  }

  .gallery__stage {
    @apply relative flex w-full items-center;

    padding-inline: var(--spacing-20);
    touch-action: pan-y;
  }

  .gallery__frame {
    @apply m-0 w-full;

    border: 0.5px solid var(--gallery-border);
  }

  .gallery__mat {
    @apply flex items-center justify-center overflow-hidden;

    height: 280px;
    background: var(--gallery-mat-bg);
    padding: var(--spacing-20);
  }

  .gallery__image {
    @apply h-full w-full object-contain;
  }

  .gallery__peek,
  .gallery__button {
    @apply hidden;
  }

  .gallery__pagination {
    @apply flex flex-col items-center justify-center text-text-secondary;

    height: 100px;
    gap: var(--spacing-8);
  }

  .gallery__dots {
    @apply flex items-center;

    gap: var(--spacing-8);
  }

  .gallery__dot {
    @apply cursor-pointer border-0 p-0;

    width: 6px;
    height: 6px;
    background: var(--color-greige);
  }

  .gallery__dot[aria-current] {
    background: var(--color-ink);
  }

  .gallery__counter {
    @apply font-sans text-body;

    line-height: var(--text-body--line-height);
  }

  .gallery__caption-section {
    @apply flex flex-col;

    gap: var(--spacing-16);
    padding: 0 var(--spacing-20) var(--spacing-24);
  }

  .gallery--single .gallery__caption-section {
    padding-top: var(--spacing-24);
  }

  :global(.gallery__caption-list) {
    @apply flex flex-col;

    width: 100%;
    gap: var(--spacing-16);
  }

  :global(.gallery__caption-item) {
    @apply flex flex-col;

    gap: var(--spacing-8);
  }

  :global(.gallery__caption-title),
  :global(.gallery__caption-text) {
    @apply font-mono;

    line-height: 1.4;
  }

  :global(.gallery__caption-title) {
    font-size: var(--text-caption);
  }

  :global(.gallery__caption-text) {
    @apply text-text-secondary;

    font-size: var(--text-caption-small);
    letter-spacing: var(--text-caption-small--letter-spacing);
  }

  :global(.gallery__object-link) {
    @apply inline-flex w-fit items-baseline font-sans text-body text-link no-underline;

    gap: 0.25em;
    border-bottom: 1px solid transparent;
    line-height: var(--text-body--line-height);
  }

  :global(.gallery__object-link-arrow) {
    @apply inline-block;
  }

  :global(.gallery__object-link:hover) {
    border-bottom-color: currentColor;
  }

  @media (min-width: 768px) {
    .gallery {
      --gallery-button-size: 70px;
      --gallery-peek-width: 72px;
      --gallery-frame-width: min(var(--container-content), calc(100vw - var(--gallery-peek-width) - var(--gallery-peek-width) - var(--spacing-20) - var(--spacing-20)));
      --gallery-group-width: calc(var(--gallery-frame-width) + var(--gallery-peek-width) + var(--gallery-peek-width) + var(--spacing-20) + var(--spacing-20));
    }

    .gallery__title-section {
      width: var(--gallery-frame-width);
      margin-inline: auto;
      padding: var(--spacing-40) 0 var(--spacing-24);
    }

    .gallery__stage {
      @apply items-start justify-center;

      gap: var(--spacing-20);
      padding-inline: 0;
    }

    .gallery__peek {
      @apply hidden overflow-hidden;

      width: var(--gallery-peek-width);
      height: 440px;
      flex: 0 0 var(--gallery-peek-width);
      border: 0.5px solid rgb(38 37 30 / 60%);
      opacity: 0.8;
    }

    .gallery__peek img {
      @apply h-full w-full object-cover;

      opacity: 0.24;
    }

    .gallery__peek.is-empty img {
      opacity: 0;
    }

    .gallery__frame {
      @apply min-w-0;

      width: var(--gallery-frame-width);
      flex: 0 1 var(--gallery-frame-width);
    }

    .gallery__mat {
      height: 440px;
      padding: var(--spacing-32);
    }

    .gallery__button {
      @apply absolute inline-flex cursor-pointer items-center justify-center;

      z-index: 2;
      top: 185px;
      width: var(--gallery-button-size);
      height: var(--gallery-button-size);
      border: 1px solid var(--color-ink);
      background: var(--color-surface);
      color: var(--color-ink);
      line-height: 1;
    }

    .gallery__button-icon {
      width: 24px;
      height: 24px;
      overflow: visible;
      fill: none;
      stroke: currentColor;
      stroke-width: 2px;
      stroke-linecap: square;
      stroke-linejoin: miter;
    }

    .gallery__button:hover:not(:disabled) {
      background: var(--color-ink);
      color: var(--color-paper);
    }

    .gallery__button--prev {
      left: calc((100% - var(--gallery-group-width)) / 2 + (var(--gallery-peek-width) - var(--gallery-button-size)) / 2);
    }

    .gallery__button--next {
      right: calc((100% - var(--gallery-group-width)) / 2 + (var(--gallery-peek-width) - var(--gallery-button-size)) / 2);
    }

    .gallery__button:disabled {
      @apply cursor-not-allowed;

      border-color: transparent;
      background: var(--color-oat);
      color: #cfd3d5;
    }

    .gallery__pagination {
      height: auto;
      @apply items-end p-0;
    }

    .gallery__dots {
      @apply hidden;
    }

    .gallery__counter {
      font-size: var(--text-body);
    }

    .gallery__caption-section {
      @apply grid items-start;

      grid-template-columns: minmax(0, 1fr) auto;
      width: var(--gallery-frame-width);
      margin-inline: auto;
      gap: var(--spacing-16) var(--spacing-24);
      padding: var(--spacing-32) 0 var(--spacing-24);
    }

    .gallery__pagination {
      grid-column: 2;
      grid-row: 1;
      @apply justify-self-end;
    }

    :global(.gallery__caption-list) {
      grid-column: 1;
      grid-row: 1;
    }


    .gallery--single .gallery__peek,
    .gallery--single .gallery__button,
    .gallery--single .gallery__pagination {
      @apply hidden;
    }

    .gallery--single .gallery__stage {
      width: var(--gallery-frame-width);
      margin-inline: auto;
      padding-inline: 0;
    }
  }

  @media (min-width: 1440px) {
    .gallery {
      --gallery-peek-width: 168.5px;
      --gallery-frame-width: min(var(--container-content), calc(100vw - var(--gallery-peek-width) - var(--gallery-peek-width) - var(--spacing-20) - var(--spacing-20)));
      --gallery-group-width: calc(var(--gallery-frame-width) + var(--gallery-peek-width) + var(--gallery-peek-width) + var(--spacing-20) + var(--spacing-20));
    }

    .gallery__title-section {
      width: var(--gallery-frame-width);
      padding: var(--spacing-80) 0 var(--spacing-24);
    }

    .gallery__stage {
      @apply items-center justify-center;
    }

    .gallery__peek {
      width: var(--gallery-peek-width);
      height: 608px;
      flex-basis: var(--gallery-peek-width);
    }

    .gallery__mat {
      height: 608px;
    }

    .gallery__button {
      top: 269px;
    }

    .gallery__pagination {
      right: 188px;
      height: auto;
      padding: 0;
    }

    .gallery__counter {
      font-size: var(--text-lead);
      line-height: var(--text-lead--line-height);
    }

    .gallery__caption-section {
      grid-template-columns: minmax(0, 1fr) auto;
      width: var(--gallery-frame-width);
      padding: var(--spacing-32) 0 var(--spacing-24);
    }

    .gallery--single {
      padding-inline: 0;
    }

    .gallery--single .gallery__title-section {
      padding-inline: 0;
    }

    .gallery--single .gallery__stage,
    .gallery--single .gallery__caption-section {
      width: var(--gallery-frame-width);
      margin-inline: auto;
      padding-inline: 0;
    }

    .gallery--single .gallery__mat {
      height: 600px;
    }
  }
</style>
