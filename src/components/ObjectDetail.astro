---
import type { Artwork } from "../data/artworks";

interface Props {
  artwork: Artwork;
}

const { artwork } = Astro.props;
---

<section class="object-detail container">
  <div class="object-detail__media">
    <div class="object-detail__image">
      <span class="object-detail__image-label label-mono">Objektabbildung</span>
    </div>
    <p class="object-detail__caption">{artwork.caption}</p>
    <p class="object-detail__credit label-mono">{artwork.credit}</p>
  </div>

  <div class="object-detail__info">
    <span class="object-detail__section-label label-mono">Objekt</span>
    <h1 class="object-detail__title">{artwork.title}</h1>
    <hr class="object-detail__divider" />

    <dl class="object-detail__meta">
      <div class="object-detail__meta-row">
        <dt class="label-mono">Künstler</dt>
        <dd>
          {artwork.artist}
          {artwork.textAuthor && (
            <span class="object-detail__sub-value label-mono">Text: {artwork.textAuthor}</span>
          )}
        </dd>
      </div>
      <div class="object-detail__meta-row">
        <dt class="label-mono">Datum</dt>
        <dd>{artwork.date}</dd>
      </div>
      <div class="object-detail__meta-row">
        <dt class="label-mono">Material und Technik</dt>
        <dd>{artwork.materialTechnique}</dd>
      </div>
      <div class="object-detail__meta-row">
        <dt class="label-mono">Institution</dt>
        <dd>{artwork.institution}</dd>
      </div>
      <div class="object-detail__meta-row">
        <dt class="label-mono">Inventar Nummer</dt>
        <dd>{artwork.inventory}</dd>
      </div>
    </dl>

    <a href="/02/illustrationen" class="object-detail__back label-mono">Zurück zur Galerie →</a>
  </div>
</section>

<style>
  .object-detail {
    display: grid;
    grid-template-columns: 1fr 415px;
    gap: 80px;
    padding-top: 24px;
    padding-bottom: 60px;
  }

  .object-detail__media {
    min-width: 0;
  }

  .object-detail__image {
    position: relative;
    aspect-ratio: 775 / 691;
    background: var(--color-gray-200);
    border: 1px solid var(--color-gray-300);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .object-detail__image-label {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(255, 255, 255, 0.9);
    padding: 8px 12px;
    color: var(--color-gray-700);
    text-transform: uppercase;
  }

  .object-detail__caption {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-gray-800);
    margin: 20px 0 8px;
  }

  .object-detail__credit {
    margin: 0;
    font-size: 0.6875rem;
    color: var(--color-gray-500);
  }

  .object-detail__info {
    padding-top: 8px;
  }

  .object-detail__section-label {
    display: block;
    margin-bottom: 12px;
    color: var(--color-gray-500);
    text-transform: uppercase;
  }

  .object-detail__title {
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 24px;
  }

  .object-detail__divider {
    border: 0;
    border-top: 1px solid var(--color-black);
    margin: 0 0 28px;
  }

  .object-detail__meta {
    margin: 0 0 32px;
  }

  .object-detail__meta-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-gray-300);
  }

  .object-detail__meta-row dt {
    color: var(--color-gray-600);
    text-transform: uppercase;
  }

  .object-detail__meta-row dd {
    margin: 0;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-gray-900);
  }

  .object-detail__sub-value {
    display: block;
    margin-top: 4px;
    font-size: 0.75rem;
    color: var(--color-gray-600);
    text-transform: none;
  }

  .object-detail__back {
    display: inline-block;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--color-black);
  }

  .object-detail__back:hover {
    color: var(--color-gray-700);
  }

  @media (max-width: 1100px) {
    .object-detail {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .object-detail__image {
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 640px) {
    .object-detail__meta-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .object-detail__title {
      font-size: 1.75rem;
    }
  }
</style>
