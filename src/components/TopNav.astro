---
const chapters = [
  { number: "01", title: "Stationen in Hebels Leben", slug: "/01-stationen" },
  { number: "02", title: "Allemannische Gedichte", slug: "/02-gedichte" },
  { number: "03", title: "Der Hausfreund", slug: "/03-hausfreund" },
  { number: "04", title: "Hebel, der Theologe", slug: "/04-theologe" },
  { number: "05", title: "Briefe", slug: "/05-briefe" },
  { number: "06", title: "Hebel und die Frauen", slug: "/06-frauen" },
  { number: "07", title: "Belchismus und Proteusertum", slug: "/07-belchismus" },
];
---

<header class="top-nav" data-nav-dropdown>
  <div class="container top-nav__inner">
    <a href="/" class="top-nav__brand">
      <span class="top-nav__brand-small">Johann Peter Hebel</span>
      <span class="top-nav__brand-large">Das Nachleben der Worte</span>
    </a>

    <nav class="top-nav__menu" aria-label="Hauptnavigation">
      <div class="top-nav__item top-nav__item--dropdown">
        <button
          type="button"
          class="top-nav__link top-nav__trigger"
          aria-expanded="false"
          aria-controls="nav-chapters"
        >
          Ausstellung
          <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true" class="top-nav__caret">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" />
          </svg>
        </button>

        <div id="nav-chapters" class="top-nav__dropdown" hidden>
          <p class="top-nav__dropdown-heading">Kapitel der Ausstellung</p>
          <ul class="top-nav__dropdown-list">
            {chapters.map((chapter) => (
              <li>
                <a href={chapter.slug} class="top-nav__dropdown-link">
                  <span class="top-nav__dropdown-number">{chapter.number}</span>
                  <span>{chapter.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <a href="/ueber" class="top-nav__link">Über das Projekt</a>
      <a href="/team" class="top-nav__link">Team</a>
      <a href="/kontakt" class="top-nav__link">Kontakt</a>

      <a href="/suche" class="top-nav__search" aria-label="Suche">
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.5" fill="none" />
          <path d="M12 12l4.5 4.5" stroke="currentColor" stroke-width="1.5" fill="none" />
        </svg>
      </a>
    </nav>
  </div>

  <div class="top-nav__border"></div>
</header>

<style>
  .top-nav {
    position: relative;
    background: var(--color-white);
  }

  .top-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 83px;
  }

  .top-nav__brand {
    display: flex;
    flex-direction: column;
    gap: 4px;
    line-height: 1.2;
  }

  .top-nav__brand-small {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gray-600);
  }

  .top-nav__brand-large {
    font-size: 1.125rem;
    font-weight: 500;
    max-width: 170px;
  }

  .top-nav__menu {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .top-nav__item {
    position: relative;
  }

  .top-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    padding: 8px 0;
    border-bottom: 2px solid transparent;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    color: var(--color-black);
  }

  .top-nav__link:hover,
  .top-nav__link[aria-expanded="true"] {
    border-bottom-color: var(--color-black);
  }

  .top-nav__trigger {
    cursor: pointer;
  }

  .top-nav__caret {
    transition: transform 0.2s ease;
  }

  .top-nav__link[aria-expanded="true"] .top-nav__caret {
    transform: rotate(180deg);
  }

  .top-nav__search {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--color-gray-400);
  }

  .top-nav__search:hover {
    border-color: var(--color-black);
  }

  .top-nav__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 340px;
    background: var(--color-white);
    border: 1px solid var(--color-gray-300);
    padding: 24px;
    z-index: 100;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .top-nav__dropdown-heading {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gray-600);
    margin: 0 0 16px;
  }

  .top-nav__dropdown-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .top-nav__dropdown-link {
    display: flex;
    gap: 16px;
    font-size: 0.9375rem;
    color: var(--color-gray-700);
  }

  .top-nav__dropdown-link:hover {
    color: var(--color-black);
  }

  .top-nav__dropdown-number {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-gray-500);
    min-width: 20px;
  }

  .top-nav__border {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-gray-300);
  }

  @media (max-width: 768px) {
    .top-nav__menu {
      gap: 16px;
    }

    .top-nav__link {
      font-size: 0.8125rem;
    }

    .top-nav__dropdown {
      position: fixed;
      left: var(--page-gutter);
      right: var(--page-gutter);
      min-width: auto;
    }
  }
</style>

<script>
  const nav = document.querySelector('[data-nav-dropdown]');
  if (nav) {
    const trigger = nav.querySelector('.top-nav__trigger');
    const dropdown = nav.querySelector('.top-nav__dropdown');

    trigger?.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      dropdown?.toggleAttribute('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target as Node)) {
        trigger?.setAttribute('aria-expanded', 'false');
        dropdown?.setAttribute('hidden', '');
      }
    });
  }
</script>
