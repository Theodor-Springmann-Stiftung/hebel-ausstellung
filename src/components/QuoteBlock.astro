---
interface Props {
  text: string;
  author: string;
}

const { text, author } = Astro.props;
---

<section class="quote-section">
  <div class="container quote-section__inner">
    <span class="quote-section__mark" aria-hidden="true">»</span>
    <blockquote class="quote-section__quote">{text}</blockquote>
    <cite class="quote-section__author label-mono">{author}</cite>
  </div>
</section>

<style>
  .quote-section {
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .quote-section__inner {
    max-width: 1000px;
    text-align: center;
  }

  .quote-section__mark {
    display: block;
    font-family: var(--font-serif);
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 16px;
  }

  .quote-section__quote {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-style: italic;
    font-weight: 500;
    line-height: 1.35;
    margin: 0 0 24px;
  }

  .quote-section__author {
    color: var(--color-gray-600);
    font-style: normal;
  }

  @media (max-width: 768px) {
    .quote-section__quote {
      font-size: 1.625rem;
    }
  }
</style>
