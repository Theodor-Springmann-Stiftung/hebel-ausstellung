---
import ArrowNav from "./ArrowNav.astro";
import type { Artwork } from "../data/artworks";

interface Props {
  artworks: Artwork[];
  initialIndex?: number;
}

const { artworks, initialIndex = 0 } = Astro.props;
const artwork = artworks[initialIndex];
---

<div class="gallery" data-gallery data-artworks={JSON.stringify(artworks)}>
  <div class="artwork-detail">
    <div class="artwork-detail__stage">
      <ArrowNav direction="left" ariaLabel="Vorheriges Werk" />

      <div class="artwork-detail__image">
        <span class="artwork-detail__image-label label-mono" data-image-label>{artwork.imageDescription}</span>
      </div>

      <ArrowNav direction="right" ariaLabel="Nächstes Werk" />
    </div>

    <p class="artwork-detail__caption" data-caption>
      <em>{artwork.caption}</em>
    </p>

    <div class="artwork-detail__dots" data-dots aria-hidden="true">
      {Array.from({ length: 5 }).map((_, i) => (
        <span
          class={`artwork-detail__dot ${i === 0 ? "artwork-detail__dot--active" : ""}`}
          data-dot
        />
      ))}
    </div>

    <div class="artwork-detail__info">
      <p class="artwork-detail__count label-mono" data-count>
        Werk {String(initialIndex + 1).padStart(2, "0")} / {String(artworks.length).padStart(2, "0")}
      </p>

      <h2 class="artwork-detail__title" data-title>{artwork.title}</h2>

      <a href={`/objekte/${artwork.id}`} class="artwork-detail__object-link label-mono" data-object-link>Zum Objekt →</a>

      <div class="artwork-detail__text">
        <p data-short-desc>{artwork.shortDescription}</p>
        <div class="artwork-detail__full-text" data-full-desc hidden>
          <p>{artwork.fullDescription}</p>
        </div>
        <button type="button" class="artwork-detail__expand label-mono" data-expand-text>
          mehr lesen
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .artwork-detail {
    display: grid;
    grid-template-columns: 1fr 332px;
    gap: 12px 64px;
    align-items: start;
    grid-template-areas:
      "stage info"
      "caption info"
      "dots info";
  }

  .artwork-detail__stage {
    grid-area: stage;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .artwork-detail__image {
    position: relative;
    flex: 1;
    aspect-ratio: 698 / 607;
    background: var(--color-gray-200);
    border: 1px solid var(--color-gray-300);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .artwork-detail__image-label {
    background: rgba(255, 255, 255, 0.9);
    padding: 10px 16px;
    color: var(--color-gray-700);
  }

  .artwork-detail__caption {
    grid-area: caption;
    margin: 16px 0 0;
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-gray-700);
  }

  .artwork-detail__dots {
    grid-area: dots;
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .artwork-detail__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1px solid var(--color-gray-600);
  }

  .artwork-detail__dot--active {
    background: var(--color-black);
    border-color: var(--color-black);
  }

  .artwork-detail__info {
    grid-area: info;
    padding-top: 28px;
  }

  .artwork-detail__count {
    color: var(--color-gray-500);
    margin: 0 0 12px;
  }

  .artwork-detail__title {
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 20px;
  }

  .artwork-detail__object-link {
    display: inline-block;
    margin-bottom: 24px;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--color-black);
  }

  .artwork-detail__object-link:hover {
    color: var(--color-gray-700);
  }

  .artwork-detail__text p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-gray-800);
    margin: 0 0 16px;
  }

  .artwork-detail__expand {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-black);
    border-bottom: 1px solid var(--color-black);
  }

  .artwork-detail__expand:hover {
    color: var(--color-gray-700);
  }

  @media (max-width: 1024px) {
    .artwork-detail {
      grid-template-columns: 1fr;
      grid-template-areas:
        "stage"
        "caption"
        "dots"
        "info";
      gap: 24px;
    }

    .artwork-detail__info {
      padding-top: 0;
    }
  }

  @media (max-width: 768px) {
    .artwork-detail__stage {
      flex-direction: column;
      align-items: stretch;
    }

    .artwork-detail__image {
      aspect-ratio: 4 / 3;
    }
  }
</style>

<script>
  (function () {
    const container = document.querySelector('[data-gallery]');
    if (!container) return;

    const artworksJson = container.getAttribute('data-artworks');
    const artworks = artworksJson ? JSON.parse(artworksJson) : [];
    let currentIndex = 0;

    const els = {
      imageLabel: container.querySelector('[data-image-label]'),
      caption: container.querySelector('[data-caption]'),
      count: container.querySelector('[data-count]'),
      title: container.querySelector('[data-title]'),
      objectLink: container.querySelector('[data-object-link]'),
      shortDesc: container.querySelector('[data-short-desc]'),
      fullDesc: container.querySelector('[data-full-desc]'),
      expandBtn: container.querySelector('[data-expand-text]'),
      thumbnails: document.querySelectorAll('[data-thumbnail]'),
      dots: container.querySelectorAll('[data-dot]'),
    };

    function render(index: number) {
      currentIndex = index;
      const artwork = artworks[index];
      if (!artwork) return;

      if (els.imageLabel) els.imageLabel.textContent = artwork.imageDescription;
      if (els.caption) els.caption.innerHTML = `<em>${artwork.caption}</em>`;
      if (els.count)
        els.count.textContent = `Werk ${String(index + 1).padStart(2, '0')} / ${String(artworks.length).padStart(2, '0')}`;
      if (els.title) els.title.textContent = artwork.title;
      if (els.shortDesc) els.shortDesc.textContent = artwork.shortDescription;
      if (els.fullDesc) {
        const p = els.fullDesc.querySelector('p');
        if (p) p.textContent = artwork.fullDescription;
        els.fullDesc.setAttribute('hidden', '');
      }
      if (els.expandBtn) els.expandBtn.textContent = 'mehr lesen';
      if (els.objectLink) els.objectLink.setAttribute('href', `/objekte/${artwork.id}`);

      els.thumbnails.forEach((thumb, i) => {
        thumb.setAttribute('data-active', String(i === index));
      });

      els.dots.forEach((dot, i) => {
        dot.classList.toggle('artwork-detail__dot--active', i === 0);
      });
    }

    container.querySelector('[data-direction="left"]')?.addEventListener('click', () => {
      const newIndex = currentIndex === 0 ? artworks.length - 1 : currentIndex - 1;
      render(newIndex);
    });

    container.querySelector('[data-direction="right"]')?.addEventListener('click', () => {
      const newIndex = currentIndex === artworks.length - 1 ? 0 : currentIndex + 1;
      render(newIndex);
    });

    els.thumbnails.forEach((thumb, i) => {
      thumb.addEventListener('click', () => render(i));
    });

    els.expandBtn?.addEventListener('click', () => {
      const isHidden = els.fullDesc?.hasAttribute('hidden');
      if (isHidden) {
        els.fullDesc?.removeAttribute('hidden');
        if (els.expandBtn) els.expandBtn.textContent = 'weniger lesen';
      } else {
        els.fullDesc?.setAttribute('hidden', '');
        if (els.expandBtn) els.expandBtn.textContent = 'mehr lesen';
      }
    });
  })();
</script>
