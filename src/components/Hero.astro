---
interface Props {
  chapterNumber: string;
  chapterTitle: string;
  sectionNumber: string;
  sectionTitle: string;
  imageDescription?: string;
}

const { chapterNumber, chapterTitle, sectionNumber, sectionTitle, imageDescription = "Hero — Lorem ipsum dolor sit amet" } = Astro.props;
---

<section class="hero">
  <div class="hero__image">
    <div class="hero__description">
      <span class="label-mono">{imageDescription}</span>
    </div>
  </div>
  <div class="hero__gradient"></div>
  <div class="container hero__content">
    <p class="label-mono hero__chapter">Kapitel {chapterNumber} — {chapterTitle}</p>
    <h1 class="hero__title">
      <span class="hero__number">{sectionNumber}</span>
      <span class="hero__name">{sectionTitle}</span>
    </h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 600px;
    overflow: hidden;
    background: var(--color-gray-300);
  }

  .hero__image {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-gray-300) 0%, var(--color-gray-500) 100%);
  }

  .hero__description {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.9);
    padding: 7px 13px;
  }

  .hero__description .label-mono {
    color: var(--color-gray-700);
  }

  .hero__gradient {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 330px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.7) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 60px;
    color: var(--color-white);
  }

  .hero__chapter {
    margin: 0 0 16px;
    opacity: 0.9;
  }

  .hero__title {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    margin: 0;
    font-weight: 500;
    line-height: 1;
  }

  .hero__number {
    font-size: 2rem;
    font-weight: 400;
    padding-bottom: 8px;
  }

  .hero__name {
    font-size: 4rem;
  }

  @media (max-width: 1024px) {
    .hero {
      height: 480px;
    }

    .hero__name {
      font-size: 3rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 400px;
    }

    .hero__title {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }

    .hero__number {
      font-size: 1.5rem;
      padding-bottom: 0;
    }

    .hero__name {
      font-size: 2.25rem;
    }
  }
</style>
