---
import type { Subchapter } from "../data/chapter";
import ArtworkDetail from "./ArtworkDetail.astro";
import ThumbnailStrip from "./ThumbnailStrip.astro";

interface Props {
  subchapter: Subchapter;
}

const { subchapter } = Astro.props;
const firstArtwork = subchapter.artworks[0];
---

<section class="gallery-section">
  <div class="container">
    <p class="gallery-section__header label-mono">Galerie · {subchapter.artworks.length} Werke</p>
  </div>

  <div class="container gallery-section__content">
    <ArtworkDetail artworks={subchapter.artworks} initialIndex={0} />
  </div>

  <ThumbnailStrip artworks={subchapter.artworks} currentId={firstArtwork.id} />
</section>

<style>
  .gallery-section {
    padding-top: var(--section-space);
    padding-bottom: 40px;
  }

  .gallery-section__header {
    margin: 0 0 40px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-black);
  }

  .gallery-section__content {
    padding-top: 40px;
  }
</style>
