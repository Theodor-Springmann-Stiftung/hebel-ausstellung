---
interface Props {
  prev?: { slug: string; title: string };
  next?: { slug: string; title: string };
}

const { prev, next } = Astro.props;
---

<nav class="prev-next container" aria-label="Unterkapitelnavigation">
  <div class="prev-next__inner">
    {prev ? (
      <a href={`/${prev.slug}`} class="prev-next__link prev-next__link--prev">
        <span class="label-mono prev-next__label">← Vorherige Sektion {prev.slug.split("/").pop()}</span>
        <span class="prev-next__title">{prev.title}</span>
      </a>
    ) : (
      <span />
    )}

    {next ? (
      <a href={`/${next.slug}`} class="prev-next__link prev-next__link--next">
        <span class="label-mono prev-next__label">Nächste Sektion {next.slug.split("/").pop()} →</span>
        <span class="prev-next__title">{next.title}</span>
      </a>
    ) : (
      <span />
    )}
  </div>
</nav>

<style>
  .prev-next {
    padding-top: 60px;
    padding-bottom: 60px;
  }

  .prev-next__inner {
    display: flex;
    justify-content: space-between;
    gap: 40px;
  }

  .prev-next__link {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .prev-next__link--next {
    text-align: right;
  }

  .prev-next__label {
    color: var(--color-gray-500);
  }

  .prev-next__title {
    font-size: 1rem;
    font-weight: 500;
  }

  .prev-next__link:hover .prev-next__title {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .prev-next__inner {
      flex-direction: column;
      gap: 24px;
    }

    .prev-next__link--next {
      text-align: left;
    }
  }
</style>
