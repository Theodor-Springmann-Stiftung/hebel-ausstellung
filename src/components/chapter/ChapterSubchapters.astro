---
import type { CollectionEntry } from "astro:content";
import { getEntry, render } from "astro:content";
import { subchapterHref } from "../../lib/content";
import { markdownToPlainText, renderInlineMarkdown } from "../../lib/markdown";
import { getNavigationImageSource, resolveContentImage } from "../../lib/object-images";

const { chapter } = Astro.props as { chapter: CollectionEntry<"chapters"> };
const { Content } = await render(chapter);
const subchapters = await Promise.all(
  (chapter.data.unterkapitel ?? []).map(async (reference) => {
    const subchapter = await getEntry(reference);

    if (!subchapter) return undefined;

    const hero = await resolveContentImage(subchapter.data.hero);
    const image = hero.asset;
    const imageSource = await getNavigationImageSource(
      image,
      "(min-width: 1440px) 624px, (min-width: 768px) calc((100vw - 84px) / 2), calc(100vw - 40px)",
    );

    return { subchapter, hero, image, imageSource };
  }),
);
const availableSubchapters = subchapters.filter(Boolean);
---

<section class="chapter-overview">
  <div class="chapter-overview__text"><Content /></div>

  {availableSubchapters.length > 0 && (
    <nav class="chapter-overview__navigation" aria-label={`${chapter.data.navTitel} Unterkapitel`}>
      <h2>Unterkapitel</h2>
      <ol class="chapter-overview__list">
        {availableSubchapters.map(({ subchapter, hero, image, imageSource }) => (
          <li class="chapter-overview__card">
            <a href={subchapterHref(chapter.data.nummer, subchapter.data.nummer)}>
              <span
                class:list={{
                  "chapter-overview__image-frame": true,
                  "chapter-overview__image-frame--texture": image.height > image.width * 1.25,
                }}
                style={image.height > image.width * 1.25 ? `background-image: url(${imageSource.smallestSrc})` : undefined}
              >
                <img
                  src={imageSource.src}
                  srcset={imageSource.srcset}
                  sizes={imageSource.sizes}
                  alt={markdownToPlainText(hero.entry?.data.altText || subchapter.data.titel)}
                  width={image.width}
                  height={image.height}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              <span class="chapter-overview__meta">
                <span class="chapter-overview__title" set:html={renderInlineMarkdown(subchapter.data.titel)}></span>
                <span class="chapter-overview__link">Weiterlesen →</span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )}
</section>

<style>
  @reference "../../styles/global.css";

  .chapter-overview {
    @apply bg-paper;
  }

  .chapter-overview__text :global(> p) {
    @apply font-sans text-lead text-text-primary;

    width: calc(100% - var(--spacing-40));
    max-width: var(--container-text);
    margin-inline: auto;
    padding-block: var(--spacing-48);
    line-height: var(--text-lead--line-height);
  }

  .chapter-overview__text :global(> blockquote) {
    display: flex;
    width: calc(100% - var(--spacing-48));
    margin: 0 auto;
    border-left: 0.5px solid var(--color-ink);
    padding-left: var(--spacing-24);
    padding-block: var(--spacing-40);
    flex-direction: column;
    gap: var(--spacing-24);
  }

  .chapter-overview__text :global(> blockquote > p) {
    margin: 0;
  }

  .chapter-overview__text :global(> blockquote > p:first-child) {
    @apply font-display font-normal italic text-text-primary;

    font-size: 1.625rem;
    line-height: 1.3;
    letter-spacing: 0.015em;
  }

  .chapter-overview__text :global(> blockquote > p:first-child::before) {
    @apply block font-display not-italic;

    margin-bottom: var(--spacing-4);
    content: "»";
    font-size: var(--text-display);
    line-height: 1;
  }

  .chapter-overview__text :global(> blockquote > p:nth-child(2)) {
    @apply flex items-center font-display font-normal not-italic text-text-primary;

    gap: var(--spacing-12);
    font-size: 1.25rem;
    line-height: 1.25;
    letter-spacing: 0.01em;
  }

  .chapter-overview__text :global(> blockquote > p:nth-child(2)::before) {
    @apply block flex-none rounded-full;

    width: var(--spacing-56);
    height: var(--spacing-56);
    flex-basis: var(--spacing-56);
    border: 0.5px solid var(--color-ink);
    background-image: url("../../assets/objects/Hebel_Portraet_Mueller.jpg");
    background-position: 68% 50%;
    background-size: auto 100%;
    content: "";
  }

  .chapter-overview__text :global(> blockquote > p:nth-child(3)) {
    @apply font-mono font-normal not-italic text-text-secondary;

    margin-left: calc(var(--spacing-56) + var(--spacing-12));
    font-size: var(--text-caption);
    line-height: normal;
  }

  .chapter-overview__navigation {
    display: flex;
    padding: var(--spacing-48) var(--spacing-20) var(--spacing-64);
    flex-direction: column;
    gap: var(--spacing-32);
  }

  .chapter-overview__navigation h2 {
    @apply font-display font-normal text-text-primary;

    font-size: var(--text-display);
    line-height: var(--text-display--line-height);
  }

  .chapter-overview__list {
    display: grid;
    margin: 0;
    padding: 0;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--spacing-32);
    list-style: none;
  }

  .chapter-overview__card a {
    display: flex;
    color: var(--color-text-primary);
    flex-direction: column;
    gap: var(--spacing-16);
    text-decoration: none;
  }

  .chapter-overview__image-frame {
    display: block;
    height: 200px;
    overflow: hidden;
    border: 0.5px solid var(--color-ink);
    background: #faf8e4;
  }

  .chapter-overview__image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease-out;
  }

  .chapter-overview__image-frame--texture {
    background-position: left center;
    background-repeat: repeat;
    background-size: auto 80%;
  }

  .chapter-overview__image-frame--texture img {
    opacity: 0;
  }

  .chapter-overview__meta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .chapter-overview__title {
    @apply font-display font-normal text-text-primary;

    font-size: 1.25rem;
    line-height: 1.25;
    letter-spacing: 0.01em;
  }

  .chapter-overview__link {
    @apply font-sans font-normal text-link;

    font-size: 0.75rem;
    line-height: 1.5;
  }

  .chapter-overview__card a:hover .chapter-overview__image-frame img {
    transform: scale(1.015);
  }

  .chapter-overview__card a:hover .chapter-overview__link {
    text-decoration: underline;
  }

  .chapter-overview__card a:focus-visible {
    outline-offset: var(--spacing-4);
  }

  @media (prefers-reduced-motion: reduce) {
    .chapter-overview__image-frame img {
      transition: none;
    }
  }

  @media (min-width: 768px) {
    .chapter-overview__text :global(> p) {
      width: 522px;
      padding-block: var(--spacing-64);
    }

    .chapter-overview__text :global(> blockquote) {
      width: calc(100% - var(--spacing-64));
      max-width: var(--container-content);
      padding-left: var(--spacing-48);
      padding-block: var(--spacing-64);
      gap: var(--spacing-32);
    }

    .chapter-overview__text :global(> blockquote > p:first-child) {
      font-size: 2.25rem;
      line-height: normal;
    }

    .chapter-overview__text :global(> blockquote > p:first-child::before) {
      margin-bottom: var(--spacing-8);
      font-size: 4rem;
    }

    .chapter-overview__text :global(> blockquote > p:nth-child(2)) {
      gap: var(--spacing-16);
      font-size: var(--text-h5);
    }

    .chapter-overview__text :global(> blockquote > p:nth-child(2)::before) {
      width: var(--spacing-40);
      height: var(--spacing-40);
      flex-basis: var(--spacing-40);
    }

    .chapter-overview__text :global(> blockquote > p:nth-child(3)) {
      margin-left: calc(var(--spacing-40) + var(--spacing-16));
    }

    .chapter-overview__navigation {
      padding: var(--spacing-80) var(--spacing-32);
      gap: var(--spacing-40);
    }

    .chapter-overview__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--spacing-20);
      row-gap: var(--spacing-48);
    }

    .chapter-overview__card a {
      gap: var(--spacing-24);
    }

    .chapter-overview__image-frame {
      height: 240px;
    }

    .chapter-overview__meta {
      gap: var(--spacing-8);
    }

    .chapter-overview__title {
      font-size: var(--text-h3);
    }

    .chapter-overview__link {
      font-size: var(--text-body-medium);
    }
  }

  @media (min-width: 1440px) {
    .chapter-overview__text :global(> p) {
      width: var(--container-text);
    }

    .chapter-overview__text :global(> blockquote) {
      padding-left: 72px;
      padding-block: var(--spacing-80);
      gap: 38px;
    }

    .chapter-overview__text :global(> blockquote > p:first-child::before) {
      margin-bottom: 0;
      font-size: var(--text-display);
      line-height: var(--text-display--line-height);
    }

    .chapter-overview__text :global(> blockquote > p:nth-child(2)::before) {
      width: var(--spacing-48);
      height: var(--spacing-48);
      flex-basis: var(--spacing-48);
    }

    .chapter-overview__text :global(> blockquote > p:nth-child(3)) {
      margin-left: calc(var(--spacing-48) + var(--spacing-16));
    }

    .chapter-overview__navigation {
      max-width: var(--container-wide);
      margin-inline: auto;
      padding: var(--spacing-80) var(--spacing-80) var(--spacing-120);
    }

    .chapter-overview__list {
      column-gap: var(--spacing-32);
      row-gap: var(--spacing-32);
    }

    .chapter-overview__image-frame {
      height: 320px;
    }
  }
</style>
