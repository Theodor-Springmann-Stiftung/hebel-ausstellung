---
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import Gallery from "../gallery/Gallery.astro";
import { findObjectImage, getGalleryImageSource, imageReferenceId } from "../../lib/object-images";
import { renderInlineMarkdown } from "../../lib/markdown";

type Section = CollectionEntry<"chapters"> | CollectionEntry<"subchapters">;

const { section } = Astro.props as { section: Section };
const { Content } = await render(section);
const imageEntriesById = new Map((await getCollection("images")).map((entry) => [entry.id, entry]));

const resolveAvailableImage = (reference) => {
  const id = imageReferenceId(reference);
  const normalizedId = id.toLowerCase().replaceAll(".", "");
  const entry = imageEntriesById.get(id) ?? imageEntriesById.get(normalizedId);
  const asset = findObjectImage(entry?.data.dateiname ?? id);

  return asset ? { id, asset, entry } : undefined;
};

const galleries = await Promise.all(
  (section.data.galerien ?? []).map(async (galleryReference) => {
    const gallery = await getEntry(galleryReference);

    if (!gallery) return undefined;

    const { Content: GalleryContent } = await render(gallery);
    const imageEntries = gallery.data.bilder.map(resolveAvailableImage).filter(Boolean);
    const bilder = await Promise.all(
      imageEntries.map(async (imageEntry) => {
        const metadata = imageEntry.entry?.data;
        const objectEntries = metadata?.objekte?.length
          ? await Promise.all(metadata.objekte.map((objectReference) => getEntry(objectReference)))
          : [];

        return {
          src: await getGalleryImageSource(imageEntry.asset),
          alt: metadata?.altText,
          beschriftung: metadata?.beschriftung,
          nachweis: metadata?.nachweis,
          objekte: objectEntries
            .map((objectEntry, objectIndex) => objectEntry && ({
              slug: objectEntry.data.slug,
              position: metadata?.objektPositionen?.[objectIndex] ?? objectEntry.data.position,
              transkription: objectEntry.data.transkription,
              titel: objectEntry.data.titel ?? "",
              urheber: objectEntry.data.urheber,
              datierung: objectEntry.data.datierung,
              materialTechnik: objectEntry.data.materialTechnik,
              institution: objectEntry.data.institution,
            }))
            .filter(Boolean),
        };
      }),
    );

    return { gallery, GalleryContent, bilder };
  }),
);
---

<section class="section-intro">
  <div class="section-intro__text"><Content /></div>
</section>

{galleries.filter(Boolean).map(({ gallery, GalleryContent, bilder }, index) => (
  <section class="section-gallery" id={String(index + 1)}>
    {bilder.length > 0 ? (
      <Gallery
        titel={gallery.data.titel}
        beschriftung={gallery.data.beschriftung}
        untertitel={gallery.data.untertitel}
        farbe={gallery.data.farbe}
        bilder={bilder}
      />
    ) : (
      <header class="section-gallery__text-header">
        <h2 set:html={renderInlineMarkdown(gallery.data.titel)}></h2>
        {gallery.data.beschriftung && <p set:html={renderInlineMarkdown(gallery.data.beschriftung)}></p>}
        {gallery.data.untertitel && <p set:html={renderInlineMarkdown(gallery.data.untertitel)}></p>}
      </header>
    )}
    <div class="section-gallery__body"><GalleryContent /></div>
  </section>
))}

<style>
  @reference "../../styles/global.css";

  .section-intro,
  .section-gallery__body {
    @apply bg-paper;
  }

  .section-gallery__text-header {
    display: flex;
    padding: var(--spacing-48) var(--spacing-20) var(--spacing-24);
    background: var(--color-oat);
    flex-direction: column;
    gap: var(--spacing-12);
  }

  .section-gallery__text-header h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: normal;
    line-height: var(--text-h2--line-height);
  }

  .section-gallery__text-header p {
    max-width: var(--container-text);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
  }

  .section-gallery__body {
    @apply flex flex-col;
  }

  .section-intro {
    padding: var(--spacing-48) var(--spacing-20);
  }

  .section-intro__text :global(> p),
  .section-gallery__body :global(> p) {
    max-width: var(--container-text);
    margin-inline: auto;
  }

  .section-intro__text :global(> p),
  .section-gallery__body :global(> p) {
    @apply font-sans text-body text-text-primary;

    line-height: var(--text-body--line-height);
  }

  .section-gallery__body :global(> p) {
    hyphens: auto;
  }

  .section-intro__text :global(> p) {
    font-size: var(--text-body);
  }

  .section-gallery__body :global(> p) {
    padding-inline: var(--spacing-20);
    order: 1;
  }

  .section-gallery__body :global(> p:first-of-type) {
    padding-top: var(--spacing-48);
  }

  .section-gallery__body :global(> p + p) {
    margin-top: var(--spacing-16);
  }

  .section-gallery__body :global(> p:last-of-type) {
    padding-bottom: var(--spacing-48);
  }

  .section-gallery__body :global(> blockquote) {
    width: calc(100% - var(--spacing-48));
    max-width: var(--container-content);
    margin: var(--spacing-40) auto;
    border-left: 0.5px solid var(--color-ink);
    padding-left: var(--spacing-24);
    order: 2;
  }

  .section-gallery + .section-gallery::before {
    display: block;
    height: var(--spacing-80);
    margin-inline: var(--spacing-20);
    border-top: 0.5px solid var(--color-ink);
    content: "";
    transform: translateY(var(--spacing-40));
  }

  .section-gallery__body :global(> blockquote::before) {
    @apply block font-display;

    content: "»";
    font-size: var(--text-display);
    line-height: 1;
    margin-bottom: var(--spacing-4);
  }

  .section-gallery__body :global(> blockquote > p) {
    @apply font-display text-h4 font-normal italic;

    margin: 0;
    line-height: normal;
  }

  .section-gallery__body :global(> blockquote > p + p) {
    margin-top: 0.5em;
  }

  .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)) {
    @apply flex items-center font-display text-lead font-normal not-italic;

    gap: var(--spacing-12);
    margin-top: var(--spacing-24);
    line-height: 1.25;
    letter-spacing: 0.01em;
  }

  .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)::before) {
    @apply block flex-none rounded-full;

    width: var(--spacing-56);
    height: var(--spacing-56);
    flex-basis: var(--spacing-56);
    border: 0.5px solid var(--color-ink);
    background-image: url("../../assets/objects/Hebel_Portraet_Mueller.jpg");
    background-position: 68% 50%;
    background-size: auto 100%;
    content: "";
  }

  .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:last-child) {
    margin-left: calc(var(--spacing-56) + var(--spacing-12));
    margin-top: 2px;
    @apply font-mono text-caption font-normal not-italic text-text-secondary;

    line-height: normal;
  }

  @media (min-width: 768px) {
    .section-intro,
    .section-gallery__body :global(> p) {
      padding-inline: var(--spacing-32);
    }

    .section-gallery__body :global(> p:first-of-type) {
      padding-top: var(--spacing-64);
    }

    .section-gallery__body :global(> p:last-of-type) {
      padding-bottom: var(--spacing-64);
    }

    .section-gallery__body :global(> blockquote) {
      width: calc(100% - var(--spacing-64));
      margin-block: var(--spacing-64);
      margin-inline: auto;
      padding-left: var(--spacing-48);
    }

    .section-intro {
      padding-block: var(--spacing-64);
    }

    .section-intro__text :global(> p) {
      max-width: 522px;
      font-size: var(--text-lead);
      line-height: var(--text-lead--line-height);
    }

    .section-gallery + .section-gallery::before {
      margin-inline: var(--spacing-32);
    }

    .section-gallery__body :global(> blockquote::before) {
      font-size: 4rem;
      margin-bottom: var(--spacing-8);
    }

    .section-gallery__body :global(> blockquote > p) {
      font-size: 2.25rem;
      letter-spacing: 0.015em;
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)) {
      gap: var(--spacing-16);
      margin-top: var(--spacing-32);
      font-size: var(--text-h5);
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)::before) {
      width: var(--spacing-40);
      height: var(--spacing-40);
      flex-basis: var(--spacing-40);
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:last-child) {
      margin-left: calc(var(--spacing-40) + var(--spacing-16));
      font-size: 1rem;
    }
  }

  @media (min-width: 1440px) {
    .section-intro,
    .section-gallery__body :global(> p) {
      padding-inline: 0;
    }

    .section-intro {
      padding-block: var(--spacing-80);
    }

    .section-intro__text :global(> p) {
      max-width: 840px;
    }

    .section-gallery__body :global(> blockquote) {
      margin-block: var(--spacing-80);
    }

    .section-gallery__body :global(> blockquote::before) {
      font-size: var(--text-display);
      line-height: var(--text-display--line-height);
      margin-bottom: 0;
    }

    .section-gallery + .section-gallery::before {
      max-width: 1060px;
      margin-inline: auto;
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)) {
      margin-top: 38px;
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)::before) {
      width: var(--spacing-48);
      height: var(--spacing-48);
      flex-basis: var(--spacing-48);
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:last-child) {
      margin-left: calc(var(--spacing-48) + var(--spacing-16));
    }
  }
</style>
