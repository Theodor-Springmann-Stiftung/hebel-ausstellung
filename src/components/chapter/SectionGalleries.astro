---
import type { CollectionEntry } from "astro:content";
import { getEntry, render } from "astro:content";
import type { ImageMetadata } from "astro";
import Gallery from "../gallery/Gallery.astro";

type Section = CollectionEntry<"chapters"> | CollectionEntry<"subchapters">;

const { section } = Astro.props as { section: Section };
const { Content } = await render(section);
const objectImageModules = import.meta.glob("../../assets/objects/*.{avif,gif,jpg,jpeg,png,webp}", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

const getObjectImage = (dateiname: string) => {
  const image = objectImageModules[`../../assets/objects/${dateiname}`];

  if (!image) {
    throw new Error(`Missing object image asset: ${dateiname}`);
  }

  return image;
};

const galleries = await Promise.all(
  (section.data.galerien ?? []).map(async (galleryReference) => {
    const gallery = await getEntry(galleryReference);

    if (!gallery) return undefined;

    const { Content: GalleryContent } = await render(gallery);
    const imageEntries = await Promise.all(gallery.data.bilder.map((imageReference) => getEntry(imageReference)));
    const bilder = await Promise.all(
      imageEntries.filter(Boolean).map(async (imageEntry) => {
        const objectEntries = imageEntry.data.objekte?.length
          ? await Promise.all(imageEntry.data.objekte.map((objectReference) => getEntry(objectReference)))
          : [];

        return {
          src: getObjectImage(imageEntry.data.dateiname),
          alt: imageEntry.data.altText,
          beschriftung: imageEntry.data.beschriftung,
          nachweis: imageEntry.data.nachweis,
          objekte: objectEntries.filter(Boolean).map((objectEntry) => ({
            slug: objectEntry.data.slug,
            titel: objectEntry.data.titel ?? "",
            urheber: objectEntry.data.urheber,
            datierung: objectEntry.data.datierung,
            materialTechnik: objectEntry.data.materialTechnik,
            institution: objectEntry.data.institution,
            inventarnummer: objectEntry.data.inventarnummer,
          })),
        };
      }),
    );

    return { gallery, GalleryContent, bilder };
  }),
);
---

<section class="section-intro">
  <h1>{section.data.titel}</h1>
  <div class="section-intro__text"><Content /></div>
</section>

{galleries.filter(Boolean).map(({ gallery, GalleryContent, bilder }) => (
  <section class="section-gallery">
    <Gallery
      titel={gallery.data.titel}
      beschriftung={gallery.data.beschriftung}
      untertitel={gallery.data.untertitel}
      farbe={gallery.data.farbe}
      bilder={bilder}
    />
    <div class="section-gallery__body"><GalleryContent /></div>
  </section>
))}

<style>
  @reference "../../styles/global.css";

  .section-intro,
  .section-gallery__body {
    @apply bg-paper;
  }

  .section-gallery__body {
    @apply flex flex-col;
  }

  .section-intro {
    padding: var(--spacing-64) var(--spacing-20);
  }

  .section-intro > h1,
  .section-intro__text :global(> p),
  .section-gallery__body :global(> p) {
    max-width: var(--container-text);
    margin-inline: auto;
  }

  .section-intro > h1 {
    @apply font-display text-h1 font-normal text-text-primary;
  }

  .section-intro__text :global(> p),
  .section-gallery__body :global(> p) {
    @apply font-sans text-body text-text-primary;

    margin-top: var(--spacing-24);
    line-height: var(--text-body--line-height);
  }

  .section-gallery__body :global(> p) {
    padding: var(--spacing-64) var(--spacing-20);
    order: 1;
  }

  .section-gallery__body :global(> blockquote) {
    max-width: var(--container-content);
    margin: var(--spacing-40) var(--spacing-24);
    border-left: 0.5px solid var(--color-ink);
    padding-left: var(--spacing-24);
    order: 2;
  }

  .section-gallery__body :global(> blockquote::before) {
    @apply block font-display;

    content: "»";
    font-size: var(--text-display);
    line-height: 1;
    margin-bottom: var(--spacing-4);
  }

  .section-gallery__body :global(> blockquote > p) {
    @apply font-display text-h4 font-normal italic;

    margin: 0;
    line-height: normal;
  }

  .section-gallery__body :global(> blockquote > p + p) {
    margin-top: 0.5em;
  }

  .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)) {
    @apply flex items-center font-display text-lead font-normal not-italic;

    gap: var(--spacing-12);
    margin-top: var(--spacing-24);
    line-height: 1.25;
    letter-spacing: 0.01em;
  }

  .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)::before) {
    @apply block flex-none rounded-full;

    width: var(--spacing-56);
    height: var(--spacing-56);
    flex-basis: var(--spacing-56);
    border: 0.5px solid var(--color-ink);
    background-image: url("../../assets/objects/Hebel_Portraet_Mueller.jpg");
    background-position: 68% 50%;
    background-size: auto 100%;
    content: "";
  }

  .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:last-child) {
    margin-left: calc(var(--spacing-56) + var(--spacing-12));
    margin-top: 2px;
    @apply font-mono text-caption font-normal not-italic text-text-secondary;

    line-height: normal;
  }

  @media (min-width: 768px) {
    .section-intro,
    .section-gallery__body :global(> p) {
      padding-inline: var(--spacing-32);
    }

    .section-gallery__body :global(> blockquote) {
      margin-inline: auto;
      padding-left: var(--spacing-48);
    }

    .section-gallery__body :global(> blockquote::before) {
      font-size: 4rem;
      margin-bottom: var(--spacing-8);
    }

    .section-gallery__body :global(> blockquote > p) {
      font-size: 2.25rem;
      letter-spacing: 0.015em;
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)) {
      gap: var(--spacing-16);
      margin-top: var(--spacing-32);
      font-size: var(--text-h5);
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)::before) {
      width: var(--spacing-40);
      height: var(--spacing-40);
      flex-basis: var(--spacing-40);
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:last-child) {
      margin-left: calc(var(--spacing-40) + var(--spacing-16));
      font-size: 1rem;
    }
  }

  @media (min-width: 1440px) {
    .section-intro,
    .section-gallery__body :global(> p) {
      padding-inline: 0;
    }

    .section-intro {
      padding-block: var(--spacing-80);
    }

    .section-gallery__body :global(> blockquote::before) {
      font-size: var(--text-display);
      line-height: var(--text-display--line-height);
      margin-bottom: 0;
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)) {
      margin-top: 38px;
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:nth-last-child(2)::before) {
      width: var(--spacing-48);
      height: var(--spacing-48);
      flex-basis: var(--spacing-48);
    }

    .section-gallery__body :global(> blockquote:has(> p:nth-child(3)) > p:last-child) {
      margin-left: calc(var(--spacing-48) + var(--spacing-16));
    }
  }
</style>
