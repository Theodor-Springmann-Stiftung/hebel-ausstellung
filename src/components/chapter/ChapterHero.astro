---
import type { CollectionEntry } from "astro:content";
import { markdownToPlainText, renderInlineMarkdown } from "../../lib/markdown";
import { resolveContentImage } from "../../lib/object-images";

const { chapter } = Astro.props as { chapter: CollectionEntry<"chapters"> };
const hero = chapter.data.hero ? await resolveContentImage(chapter.data.hero) : undefined;
const image = hero?.asset;
const metadata = hero?.entry?.data;
---

<header class="chapter-hero">
  <h1 class="chapter-hero__title">
    <span>Kapitel {Number(chapter.data.nummer)}</span>
    <span set:html={renderInlineMarkdown(chapter.data.titel)}></span>
  </h1>

  {image && (
    <div class="chapter-hero__image-frame">
      <img
        class="chapter-hero__image"
        src={image.src}
        alt={markdownToPlainText(metadata?.altText || chapter.data.titel)}
        width={image.width}
        height={image.height}
        loading="eager"
        decoding="async"
      />
    </div>
  )}

  {(metadata?.beschriftung || metadata?.nachweis) && (
    <div class="chapter-hero__caption">
      <div class="chapter-hero__caption-inner">
        {metadata?.beschriftung && <p class="chapter-hero__caption-title" set:html={renderInlineMarkdown(metadata.beschriftung)}></p>}
        {metadata?.nachweis && <p class="chapter-hero__caption-credit" set:html={renderInlineMarkdown(metadata.nachweis)}></p>}
      </div>
    </div>
  )}
</header>

<style>
  @reference "../../styles/global.css";

  .chapter-hero {
    @apply w-full overflow-hidden bg-paper;
  }

  .chapter-hero__title {
    @apply flex flex-col items-center font-display font-normal text-text-primary;

    gap: var(--spacing-8);
    padding: var(--spacing-20);
    font-size: var(--text-h1);
    line-height: var(--text-h1--line-height);
    text-align: center;
  }

  .chapter-hero__image-frame {
    width: 100%;
    height: 360px;
    overflow: hidden;
  }

  .chapter-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .chapter-hero__caption {
    width: calc(100% - var(--spacing-20) * 2);
    margin-inline: auto;
    padding-block: var(--spacing-16);
  }

  .chapter-hero__caption-inner {
    @apply flex flex-col font-mono;

    gap: var(--spacing-4);
  }

  .chapter-hero__caption-title {
    font-size: var(--text-caption);
    line-height: 1.4;
  }

  .chapter-hero__caption-credit {
    @apply text-text-secondary;

    font-size: var(--text-caption-small);
    line-height: 1.4;
    letter-spacing: var(--text-caption-small--letter-spacing);
  }

  .chapter-hero__caption :global(a) {
    overflow-wrap: anywhere;
  }

  @media (min-width: 768px) {
    .chapter-hero__title {
      padding: var(--spacing-40) var(--spacing-48);
      font-size: var(--text-h1);
    }

    .chapter-hero__image-frame {
      height: 650px;
      border-block: 0.5px solid var(--color-ink);
    }

    .chapter-hero__caption {
      width: min(var(--container-content), calc(100vw - 72px - 72px - var(--spacing-20) - var(--spacing-20)));
      padding-block: var(--spacing-24);
    }
  }

  @media (min-width: 1440px) {
    .chapter-hero__title {
      gap: var(--spacing-20);
      padding: var(--spacing-40) var(--spacing-80);
      font-size: var(--text-display);
      line-height: var(--text-display--line-height);
    }

    .chapter-hero__image-frame {
      height: 850px;
    }

    .chapter-hero__caption {
      width: min(var(--container-content), calc(100vw - 168.5px - 168.5px - var(--spacing-20) - var(--spacing-20)));
      padding-block: var(--spacing-20);
    }

    .chapter-hero__caption-inner {
      gap: var(--spacing-10, 10px);
    }
  }
</style>
