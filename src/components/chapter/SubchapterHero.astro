---
import type { CollectionEntry } from "astro:content";
import { markdownToPlainText, renderInlineMarkdown } from "../../lib/markdown";
import { getHeroImageSource, resolveContentImage } from "../../lib/object-images";

const { chapter, subchapter } = Astro.props as {
  chapter: CollectionEntry<"chapters">;
  subchapter: CollectionEntry<"subchapters">;
};
const hero = await resolveContentImage(subchapter.data.hero);
const image = hero.asset;
const imageSource = await getHeroImageSource(image);
---

<header class="subchapter-hero">
  <img
    class="subchapter-hero__image"
    src={imageSource.src}
    srcset={imageSource.srcset}
    sizes={imageSource.sizes}
    alt={markdownToPlainText(hero.entry?.data.altText || subchapter.data.titel)}
    width={image.width}
    height={image.height}
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="subchapter-hero__gradient"></div>
  <div class="subchapter-hero__content">
    <p class="subchapter-hero__chapter">Kapitel {chapter.data.nummer}: {chapter.data.navTitel}</p>
    <h1 class="subchapter-hero__title" set:html={renderInlineMarkdown(subchapter.data.titel)}></h1>
  </div>
</header>

<style>
  @reference "../../styles/global.css";

  .subchapter-hero {
    position: relative;
    display: flex;
    width: 100%;
    height: 515px;
    overflow: hidden;
    align-items: flex-end;
    background: var(--color-oat);
  }

  .subchapter-hero__image,
  .subchapter-hero__gradient {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .subchapter-hero__image {
    object-fit: cover;
    object-position: center;
  }

  .subchapter-hero__gradient {
    background: linear-gradient(to top, #26251e 8%, rgb(38 37 30 / 40%) 41%, rgb(38 37 30 / 0%) 92%);
  }

  .subchapter-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    padding: var(--spacing-40) var(--spacing-20);
    color: var(--color-paper);
    flex-direction: column;
    gap: var(--spacing-20);
  }

  .subchapter-hero__chapter {
    @apply font-mono text-caption font-normal;

    line-height: normal;
  }

  .subchapter-hero__title {
    @apply font-display text-display font-normal;

    max-width: 985px;
    color: inherit;
    line-height: var(--text-display--line-height);
  }

  @media (min-width: 768px) {
    .subchapter-hero__content {
      padding-inline: var(--spacing-32);
    }
  }

  @media (min-width: 1440px) {
    .subchapter-hero__content {
      max-width: var(--container-wide);
      margin-inline: auto;
      padding-inline: var(--spacing-80);
    }
  }
</style>
