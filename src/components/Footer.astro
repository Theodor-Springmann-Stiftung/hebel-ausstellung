---
const footerLinks = [
  "Über die Ausstellung",
  "Team & Partners",
  "Presse Kontakt",
  "Kontakt Uns",
  "Newsletter Abonnieren",
  "Mitwirkende / Credits",
  "Impressum & Datenschutz",
  "GDPR Policy / Barrierefreiheit",
];
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__col">
      <p class="label-mono footer__heading">Die Ausstellung</p>
      <p class="footer__title">Johann Peter Hebel:<br />Das Nachleben der Worte</p>
      <p class="footer__desc">Eine virtuelle Ausstellung der Theodor-Springmann-Stiftung.</p>
      <div class="footer__socials">
        <a href="#" aria-label="LinkedIn"><span class="footer__icon" /></a>
        <a href="#" aria-label="Instagram"><span class="footer__icon" /></a>
        <a href="#" aria-label="Facebook"><span class="footer__icon" /></a>
      </div>
    </div>

    <div class="footer__col">
      <p class="label-mono footer__heading">Über uns</p>
      <hr class="footer__divider" />
      <ul class="footer__links">
        {footerLinks.map((link) => (
          <li>
            <a href="#" class="footer__link">{link}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <p class="label-mono footer__heading">Kontakt & Rechtliches</p>
      <div class="footer__logo">
        <span class="label-mono">Logo</span>
      </div>
      <address class="footer__address">
        Theodor Springmann Stiftung<br />
        Hirschgasse 2<br />
        69120 Heidelberg<br />
        <a href="mailto:tss@theodor-springmann-stiftung.de">tss@theodor-springmann-stiftung.de</a>
      </address>
    </div>
  </div>

  <div class="footer__bar">
    <div class="container">
      <p class="footer__copyright">© 2026 Theodor-Springmann-Stiftung</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-gray-300);
    padding-top: 60px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    padding-bottom: 60px;
  }

  .footer__heading {
    margin: 0 0 20px;
    color: var(--color-gray-600);
  }

  .footer__title {
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .footer__desc {
    font-size: 0.875rem;
    color: var(--color-gray-700);
    margin: 0 0 20px;
    max-width: 260px;
  }

  .footer__socials {
    display: flex;
    gap: 12px;
  }

  .footer__icon {
    display: block;
    width: 39px;
    height: 39px;
    border-radius: 50%;
    background: var(--color-gray-200);
  }

  .footer__divider {
    border: none;
    height: 1px;
    background: var(--color-gray-300);
    margin: 0 0 16px;
  }

  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__link {
    font-size: 0.9375rem;
    color: var(--color-gray-700);
  }

  .footer__link:hover {
    color: var(--color-black);
    text-decoration: underline;
  }

  .footer__logo {
    width: 265px;
    height: 123px;
    background: var(--color-gray-200);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--color-gray-500);
  }

  .footer__address {
    font-style: normal;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-gray-700);
  }

  .footer__address a:hover {
    text-decoration: underline;
  }

  .footer__bar {
    border-top: 1px solid var(--color-gray-300);
    padding: 18px 0;
  }

  .footer__copyright {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-gray-600);
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .footer__logo {
      width: 100%;
    }
  }
</style>
