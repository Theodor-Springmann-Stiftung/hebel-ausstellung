---
import Layout from "../../layouts/Layout.astro";
import TopNav from "../../components/TopNav.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ObjectDetail from "../../components/ObjectDetail.astro";
import PrevNextSubchapters from "../../components/PrevNextSubchapters.astro";
import Footer from "../../components/Footer.astro";
import { artworks, type Artwork } from "../../data/artworks";
import { subchapters } from "../../data/chapter";

export function getStaticPaths() {
  return artworks.map((artwork) => ({
    params: { id: artwork.id },
    props: { artwork },
  }));
}

interface Props {
  artwork: Artwork;
}

const { artwork } = Astro.props;

const currentIndex = subchapters.findIndex((s) => s.slug === "02/illustrationen");
const prev = subchapters[currentIndex - 1];
const next = subchapters[currentIndex + 1];
---

<Layout title={`${artwork.title} · Objekt`}>
  <TopNav />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Kapitel 2: Allemannische Gedichte", href: "/02/illustrationen" },
      { label: "Illustrationen", href: "/02/illustrationen" },
      { label: artwork.title },
    ]}
  />
  <main>
    <ObjectDetail artwork={artwork} />
    <PrevNextSubchapters prev={prev} next={next} />
  </main>
  <Footer />
</Layout>
