---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import ChapterHero from '../../components/chapter/ChapterHero.astro';
import ChapterSubchapters from '../../components/chapter/ChapterSubchapters.astro';
import SectionGalleries from '../../components/chapter/SectionGalleries.astro';
import { getChapterRoutes } from '../../lib/content';

export const getStaticPaths = getChapterRoutes;

const { chapter } = Astro.props;
const chapterLabel = `Kapitel ${Number(chapter.data.nummer)}: ${chapter.data.navTitel}`;
---

<Layout>
	<Breadcrumbs
		items={[
			{ label: 'Startseite', href: '/' },
			{ label: chapterLabel },
		]}
	/>
	<ChapterHero chapter={chapter} />
	{chapter.data.galerien ? <SectionGalleries section={chapter} /> : <ChapterSubchapters chapter={chapter} />}
</Layout>
