---
import Layout from '../layouts/Layout.astro';
import Quote from '../components/content/Quote.astro';
import { chapterHref, getOrderedChapters } from '../lib/content';
import { renderInlineMarkdown } from '../lib/markdown';
import { getObjectImage } from '../lib/object-images';
import portrait from '../assets/objects/Hebel_Portraet_Mueller.jpg';
import heroPortrait from '../assets/objects/Hebel_Portraet_Homepage.png';
import seal from '../assets/objects/Hebel_Wachssiegel.png';

const chapters = (await getOrderedChapters()).map((chapter) => ({
  number: chapter.data.nummer.padStart(2, '0'),
  title: chapter.data.navTitel,
  image: getObjectImage(chapter.data.startseitenBild),
  imageAlt: chapter.data.startseitenAltText ?? '',
  href: chapterHref(chapter.data.nummer),
  modifier: chapter.data.startseitenVariante,
}));
---

<Layout>
  <main class="home">
    <section class="home-hero" aria-labelledby="home-title">
      <img class="home-hero__image" src={heroPortrait.src} alt="Porträt Johann Peter Hebels nach einem Kupferstich von Christian Friedrich Müller" />
      <div class="home-hero__shade"></div>
      <div class="home-hero__content">
        <div class="home-hero__titles">
          <p>Johann Peter Hebel</p>
          <h1 id="home-title">Das Nachleben der Worte</h1>
        </div>
        <p class="home-hero__subtitle">Eine virtuelle Ausstellung des Hebel-Archivs der Theodor Springmann Stiftung in Heidelberg</p>
      </div>
    </section>

    <div class="home-caption">
      <p>Hebels Porträt nach dem Kupferstich von Christian Friedrich Müller (Ausschnitt)</p>
      <p>Johann Peter Hebel, Kupferstich von Christian Friedrich Müller, H 17,6 cm B 16,2 cm, Staatliche Kunsthalle Karlsruhe, Inventarnr. VII 1634</p>
    </div>

    <section class="home-introduction" aria-labelledby="introduction-title">
      <h2 id="introduction-title">Einführung in die Ausstellung</h2>
      <div class="home-introduction__layout">
        <figure class="home-introduction__seal">
          <img src={seal.src} alt="Hebels rotes Wachssiegel mit dem Proteus-Symbol" loading="lazy" decoding="async" />
          <figcaption>Hebels Wachssiegel mit dem <a href="#chapter-05">Proteus-Symbol</a></figcaption>
        </figure>
        <div class="home-introduction__copy">
          <p><strong>Am 22. September 2026</strong> jährt sich der Todestag Johann Peter Hebels zum zweihundertsten Mal. Die Mitarbeiter des Hebel-Archivs in Heidelberg haben dieses Datum zum Anlass genommen, die verschiedenen Facetten seines Schaffens in einer virtuellen Ausstellung näher zu beleuchten.</p>
          <p>Nahezu vergessen ist das übrige Werk: Die »Allemannischen Gedichte«, mit denen Hebel dazu beitrug, die deutsche Dialektdichtung salonfähig zu machen; seine »Biblischen Geschichten«, die lange Zeit Schullektüre waren; und auch seine Briefe, die einen ganz eigenen Reiz besitzen.</p>
          <p>Anhand von etwa 120 ausgewählten Manuskripten, Originaldrucken, Bildern und Objekten ruft die Ausstellung Hebels Vermächtnis in Erinnerung. In zahlreichen neuen Lektüren der Texte sichtet und sichert sie das Nachleben seiner Worte.</p>
        </div>
      </div>
    </section>

    <Quote
      text="Es ist wohl an der Zeit, daß wir unser Daseyn auf dem Planeten euch wieder einmal beurkunden."
      attribution="— JPH"
      source="Brief an Sophie Haufe vom 23. August 1826"
      portrait={portrait}
    />

    <section class="home-chapters" aria-labelledby="chapters-title">
      <header class="home-chapters__heading">
        <p>Die Ausstellung</p>
        <h2 id="chapters-title">Kapitelübersicht</h2>
      </header>
      <ol class="home-chapters__list">
        {chapters.map((chapter) => (
          <li class:list={["chapter-card", `chapter-card--${chapter.modifier}`]} id={`chapter-${chapter.number}`}>
            {chapter.href ? (
              <a href={chapter.href}>
                <span class="chapter-card__image">
                  <img src={chapter.image.src} alt={chapter.imageAlt} loading={chapter.number === '01' ? 'eager' : 'lazy'} decoding="async" />
                </span>
                <span class="chapter-card__meta">
                  <span class="chapter-card__number">Kapitel {chapter.number}</span>
                  <span class="chapter-card__title" set:html={renderInlineMarkdown(chapter.title)}></span>
                  <span class="chapter-card__link">Weiterlesen →</span>
                </span>
              </a>
            ) : (
              <div class="chapter-card__placeholder" aria-label={`${chapter.title}, in Vorbereitung`}>
                <span class="chapter-card__image">
                  <img src={chapter.image.src} alt={chapter.imageAlt} loading="lazy" decoding="async" />
                </span>
                <span class="chapter-card__meta">
                  <span class="chapter-card__number">Kapitel {chapter.number}</span>
                  <span class="chapter-card__title" set:html={renderInlineMarkdown(chapter.title)}></span>
                  <span class="chapter-card__link chapter-card__link--pending">In Vorbereitung</span>
                </span>
              </div>
            )}
          </li>
        ))}
      </ol>
    </section>
  </main>
</Layout>

<style>
  @reference "../styles/global.css";

  .home {
    max-width: 1440px;
    margin-inline: auto;
    background: var(--color-paper);
  }

  .home-hero {
    position: relative;
    left: 50%;
    display: flex;
    width: 100vw;
    height: 642px;
    margin-left: -50vw;
    overflow: hidden;
    align-items: flex-end;
    justify-content: center;
    padding: var(--spacing-40) var(--spacing-20);
    color: var(--color-paper);
  }

  .home-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 53% center;
  }

  .home-hero__shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgb(38 37 30 / 0%) 54%, rgb(38 37 30 / 90%) 86%, var(--color-ink) 100%);
  }

  .home-hero__content,
  .home-hero__titles {
    position: relative;
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .home-hero__content { gap: var(--spacing-24); }
  .home-hero__titles { gap: var(--spacing-8); font-family: var(--font-display); }
  .home-hero__titles p { font-size: 1.75rem; line-height: 1.25; }
  .home-hero__titles h1 { color: inherit; font-size: 2.5rem; line-height: 1.25; }
  .home-hero__subtitle { max-width: 500px; font-size: 0.75rem; line-height: 1.5; }

  .home-caption {
    display: flex;
    padding: var(--spacing-24) var(--spacing-20);
    flex-direction: column;
    gap: var(--spacing-8);
    font-family: var(--font-mono);
    line-height: normal;
  }

  .home-caption p:first-child { font-size: 0.75rem; }
  .home-caption p:last-child { color: var(--color-stone); font-size: 0.625rem; letter-spacing: 0.04em; }

  .home-introduction {
    display: flex;
    padding: var(--spacing-48) var(--spacing-20);
    flex-direction: column;
    gap: var(--spacing-48);
  }

  .home-introduction h2,
  .home-chapters h2 {
    font-size: 2.5rem;
    line-height: 1.25;
  }

  .home-introduction__layout,
  .home-introduction__copy {
    display: flex;
    flex-direction: column;
  }

  .home-introduction__layout { gap: var(--spacing-32); }
  .home-introduction__copy { gap: var(--spacing-24); font-size: 1.25rem; line-height: 1.35; }

  .home-introduction__seal {
    display: flex;
    width: 100%;
    margin: 0;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-16);
  }

  .home-introduction__seal img { width: min(320px, 100%); aspect-ratio: 1; object-fit: contain; }
  .home-introduction__seal figcaption { color: var(--color-stone); font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.04em; text-align: center; }

  .home-chapters { display: flex; padding: var(--spacing-48) var(--spacing-20); flex-direction: column; gap: var(--spacing-48); }
  .home-chapters__heading { display: flex; flex-direction: column; gap: var(--spacing-8); }
  .home-chapters__heading > p,
  .chapter-card__number { color: var(--color-stone); font-family: var(--font-mono); font-size: 0.75rem; line-height: normal; }
  .home-chapters__list { display: flex; margin: 0; padding: 0; flex-direction: column; gap: var(--spacing-48); list-style: none; }
  .chapter-card a,
  .chapter-card__placeholder { display: flex; color: var(--color-ink); flex-direction: column; gap: var(--spacing-20); text-decoration: none; }
  .chapter-card__image { display: flex; width: 100%; height: 280px; overflow: hidden; border: 0.5px solid var(--color-ink); background: var(--color-oat); align-items: center; justify-content: center; }
  .chapter-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform 180ms ease-out; }
  .chapter-card__meta { display: flex; padding-block: var(--spacing-8); flex-direction: column; gap: var(--spacing-8); }
  .chapter-card__title { font-family: var(--font-display); font-size: 2rem; line-height: 1.25; }
  .chapter-card__link { color: var(--color-link); font-size: 1rem; line-height: 1.5; }
  .chapter-card__link--pending { color: var(--color-stone); }
  .chapter-card a:hover .chapter-card__image img { transform: scale(1.015); }
  .chapter-card a:hover .chapter-card__link { text-decoration: underline; }
  .chapter-card--featured .chapter-card__image img { width: 153%; max-width: none; object-position: left center; }
  .chapter-card--poet .chapter-card__image { background: #faf8e4; }
  .chapter-card--poet .chapter-card__image img { width: 69%; height: 88%; object-fit: contain; }
  .chapter-card--friend .chapter-card__image { background: #d6e1f3; }
  .chapter-card--friend .chapter-card__image img { width: 57%; height: 86%; object-fit: contain; }
  .chapter-card--theologian .chapter-card__image img { object-position: center; }
  .chapter-card--proteuser .chapter-card__image img { width: 112%; max-width: none; object-position: center; }
  .chapter-card--bachelor .chapter-card__image img { object-position: center 28%; }
  .chapter-card--letter-writer .chapter-card__image img { mix-blend-mode: multiply; }

  @media (prefers-reduced-motion: reduce) {
    .chapter-card__image img { transition: none; }
  }

  @media (min-width: 768px) {
    .home-hero { height: 640px; padding: var(--spacing-64) var(--spacing-32); }
    .home-hero__image { object-position: center; }
    .home-hero__titles p { font-size: 2rem; }
    .home-hero__titles h1 { font-size: 3.75rem; line-height: 1.1; }
    .home-hero__subtitle { font-size: 0.875rem; }
    .home-caption { padding-inline: var(--spacing-32); }
    .home-caption p:first-child { font-size: 1rem; }
    .home-introduction { padding: var(--spacing-64) var(--spacing-32); }
    .home-introduction h2,
    .home-chapters h2 { font-size: 3.5rem; }
    .home-introduction__layout { gap: var(--spacing-40); }
    .home-introduction__layout { display: grid; grid-template-columns: 220px minmax(0, 1fr); }
    .home-introduction__copy { display: contents; font-size: 1.5rem; }
    .home-introduction__copy p:first-child { grid-column: 2; grid-row: 1; }
    .home-introduction__copy p:nth-child(2),
    .home-introduction__copy p:nth-child(3) { grid-column: 1 / -1; }
    .home-introduction__seal img { width: 220px; }
    .home-chapters { padding: var(--spacing-64) var(--spacing-32); gap: var(--spacing-64); }
    .home-chapters__heading > p,
    .chapter-card__number { font-size: 1rem; }
    .home-chapters__list { gap: var(--spacing-64); }
    .chapter-card__image { height: 400px; }
    .chapter-card__title { font-size: 2rem; }
    .chapter-card__link { font-size: 1.125rem; }
    .chapter-card--featured .chapter-card__image img { width: 108%; }
    .chapter-card--poet .chapter-card__image img { width: 48%; height: 87%; }
    .chapter-card--friend .chapter-card__image img { width: 42%; height: 87%; }
  }

  @media (min-width: 1440px) {
    .home-hero { height: 800px; padding: var(--spacing-64) var(--spacing-80); }
    .home-hero__shade {
      background:
        linear-gradient(180deg, rgb(0 0 0 / 80%) 0, rgb(0 0 0 / 52%) 110px, rgb(0 0 0 / 20%) 230px, transparent 360px),
        linear-gradient(180deg, transparent 45%, rgb(38 37 30 / 90%) 85%, var(--color-ink) 100%);
    }
    .home-hero__titles h1 { font-size: 5.25rem; }
    .home-caption { padding: var(--spacing-20) var(--spacing-80); }
    .home-introduction { padding: var(--spacing-64) var(--spacing-80); gap: var(--spacing-44); }
    .home-introduction__layout { grid-template-columns: 360px minmax(0, 1fr); gap: var(--spacing-64); }
    .home-introduction__copy { display: flex; gap: var(--spacing-32); font-size: 1.5rem; }
    .home-introduction__copy p { grid-column: auto; grid-row: auto; }
    .home-introduction__seal img { width: 280px; }
    .home-chapters { padding: var(--spacing-120) var(--spacing-80) var(--spacing-64); gap: var(--spacing-48); }
    .home-chapters__list { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: var(--spacing-80) var(--spacing-20); }
    .chapter-card--featured { grid-column: 1 / -1; }
    .chapter-card--poet { grid-column: 1 / span 4; }
    .chapter-card--friend { grid-column: 5 / span 2; }
    .chapter-card--theologian { grid-column: 1 / -1; }
    .chapter-card--proteuser { grid-column: 1 / span 2; }
    .chapter-card--bachelor { grid-column: 3 / span 2; }
    .chapter-card--letter-writer { grid-column: 5 / span 2; }
    .chapter-card__image { height: 280px; }
    .chapter-card--featured a { position: relative; }
    .chapter-card--featured .chapter-card__image { height: 680px; }
    .chapter-card--featured .chapter-card__image img { width: 100%; object-fit: cover; }
    .chapter-card--featured .chapter-card__meta { position: absolute; right: 0; bottom: 0; width: 524px; padding: var(--spacing-48); border: 0.5px solid var(--color-ink); background: rgb(242 241 237 / 90%); gap: var(--spacing-8); }
    .chapter-card--featured .chapter-card__link { margin-top: var(--spacing-8); font-size: 1.5rem; }
    .chapter-card--poet .chapter-card__image,
    .chapter-card--friend .chapter-card__image { height: 400px; }
    .chapter-card--theologian > .chapter-card__placeholder { display: grid; grid-template-columns: 1fr 1fr; align-items: center; }
    .chapter-card--theologian .chapter-card__image { height: 320px; }
    .chapter-card__meta { padding-block: 0; }
    .chapter-card__title { font-size: 1.75rem; }
    .chapter-card__link { font-size: 0.875rem; }
  }
</style>
