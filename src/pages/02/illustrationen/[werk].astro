---
import Layout from "../../../layouts/Layout.astro";
import TopNav from "../../../components/TopNav.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import GallerySection from "../../../components/GallerySection.astro";
import Footer from "../../../components/Footer.astro";
import { illustrationen } from "../../../data/chapter";
import { artworks } from "../../../data/artworks";

export function getStaticPaths() {
  return artworks.map((artwork) => ({
    params: { werk: artwork.id },
    props: { artwork },
  }));
}

const { werk } = Astro.params;
const artwork = artworks.find((a) => a.id === werk);
if (!artwork) {
  throw new Error(`Unknown artwork: ${werk}`);
}

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: `Kapitel ${illustrationen.chapterNumber}: ${illustrationen.chapterTitle}`, href: "/02-gedichte" },
  { label: illustrationen.sectionTitle, href: "/02/illustrationen" },
  { label: artwork.title },
];
---

<Layout title={`${artwork.title} — ${illustrationen.sectionTitle}`}>
  <TopNav />
  <Breadcrumbs items={breadcrumbs} />

  <main>
    <GallerySection
      subchapter={illustrationen}
      currentArtworkId={artwork.id}
      showMetadata={true}
      objectLinkHref={`/02/illustrationen/${artwork.id}`}
    />
  </main>

  <Footer />
</Layout>
