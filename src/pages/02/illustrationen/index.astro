---
import Layout from "../../../layouts/Layout.astro";
import TopNav from "../../../components/TopNav.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import Hero from "../../../components/Hero.astro";
import IntroSection from "../../../components/IntroSection.astro";
import QuoteBlock from "../../../components/QuoteBlock.astro";
import GallerySection from "../../../components/GallerySection.astro";
import PrevNextSubchapters from "../../../components/PrevNextSubchapters.astro";
import Footer from "../../../components/Footer.astro";
import { illustrationen } from "../../../data/chapter";

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: `Kapitel ${illustrationen.chapterNumber}: ${illustrationen.chapterTitle}`, href: "/02-gedichte" },
  { label: illustrationen.sectionTitle },
];
---

<Layout title={`${illustrationen.sectionTitle} — ${illustrationen.chapterTitle}`}>
  <TopNav />
  <Breadcrumbs items={breadcrumbs} />

  <main>
    <Hero
      chapterNumber={illustrationen.chapterNumber}
      chapterTitle={illustrationen.chapterTitle}
      sectionNumber={illustrationen.sectionNumber}
      sectionTitle={illustrationen.sectionTitle}
      imageDescription={illustrationen.heroImageDescription}
    />

    <IntroSection
      title={illustrationen.introTitle}
      paragraphs={illustrationen.introParagraphs}
    />

    <QuoteBlock
      text={illustrationen.quoteText}
      author={illustrationen.quoteAuthor}
    />

    <GallerySection
      subchapter={illustrationen}
    />

    <PrevNextSubchapters
      prev={illustrationen.prevSubchapter}
      next={illustrationen.nextSubchapter}
    />
  </main>

  <Footer />
</Layout>
