---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Seite nicht gefunden">
  <TopNav />
  <main class="container stub">
    <h1 class="stub__title">404 — Seite nicht gefunden</h1>
    <p class="stub__text">Die angeforderte Seite existiert nicht.</p>
    <a href="/" class="stub__link">Zurück zur Startseite</a>
  </main>
  <Footer />
</Layout>

<style>
  .stub {
    min-height: 60vh;
    padding-top: 120px;
    padding-bottom: 120px;
  }

  .stub__title {
    font-size: 2.5rem;
    font-weight: 500;
    margin: 0 0 16px;
  }

  .stub__text {
    color: var(--color-gray-600);
    margin: 0 0 24px;
  }

  .stub__link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    border-bottom: 1px solid var(--color-black);
  }
</style>
